<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.shape.Rectangle?>
<AnchorPane prefHeight="620.0" prefWidth="580.0" style="-fx-background-color: #eef2eb;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a36.Controller.ListeMedecinController">

    <children>
        <AnchorPane prefHeight="620.0" prefWidth="580.0">
            <children>
                <!-- Top band -->
                <Rectangle width="580" height="4" fill="#c8a84b"/>

                <!-- Table view -->
                <TableView fx:id="tableView" prefHeight="620.0" prefWidth="580">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                        <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="150"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                        <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="100"/>
                        <TableColumn fx:id="colDisponibilite" text="Disponibilité" prefWidth="100"/>
                    </columns>
                </TableView>

                <!-- Footer with close button -->
                <HBox layoutY="580" prefHeight="40" alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Fermer" onAction="#fermer" prefHeight="30" prefWidth="100"/>
                </HBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>