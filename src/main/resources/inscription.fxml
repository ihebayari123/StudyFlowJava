<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.connexion3a36.Controller.InscriptionController"
           style="-fx-background-color: #c8d8e8;">

    <!-- Background -->
    <Rectangle width="1280" height="720"
               style="-fx-fill: linear-gradient(to bottom right, #7BAFD4, #B0C9D8, #8A9BAA);"/>

    <!-- Card principale -->
    <HBox alignment="CENTER">
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 16;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 8);
                     -fx-min-width: 420; -fx-max-width: 420;">

            <!-- Header bleu -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #2979FF; -fx-background-radius: 16 16 0 0;
                         -fx-padding: 30 30 30 30;">
                <Circle radius="30" style="-fx-fill: rgba(255,255,255,0.2);"/>
                <Label text="StudyFlow"
                       style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Créez votre compte étudiant"
                       style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.8);"/>
            </VBox>

            <!-- Formulaire -->
            <VBox spacing="12" style="-fx-padding: 30 36 30 36;">

                <!-- Nom -->
                <VBox spacing="4">
                    <Label text="Nom"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #424242;"/>
                    <TextField fx:id="nomField"
                               promptText="Entrez votre nom"
                               style="-fx-background-radius: 8; -fx-padding: 10;
                                      -fx-font-size: 13; -fx-border-color: #E0E0E0;
                                      -fx-border-radius: 8; -fx-border-width: 1.5;"/>
                    <Label fx:id="nomError" text=""
                           style="-fx-font-size: 11; -fx-text-fill: #F44336;"/>
                </VBox>

                <!-- Prénom -->
                <VBox spacing="4">
                    <Label text="Prénom"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #424242;"/>
                    <TextField fx:id="prenomField"
                               promptText="Entrez votre prénom"
                               style="-fx-background-radius: 8; -fx-padding: 10;
                                      -fx-font-size: 13; -fx-border-color: #E0E0E0;
                                      -fx-border-radius: 8; -fx-border-width: 1.5;"/>
                    <Label fx:id="prenomError" text=""
                           style="-fx-font-size: 11; -fx-text-fill: #F44336;"/>
                </VBox>

                <!-- Email -->
                <VBox spacing="4">
                    <Label text="Email"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #424242;"/>
                    <TextField fx:id="emailField"
                               promptText="Entrez votre email"
                               style="-fx-background-radius: 8; -fx-padding: 10;
                                      -fx-font-size: 13; -fx-border-color: #E0E0E0;
                                      -fx-border-radius: 8; -fx-border-width: 1.5;"/>
                    <Label fx:id="emailError" text=""
                           style="-fx-font-size: 11; -fx-text-fill: #F44336;"/>
                </VBox>

                <!-- Mot de passe -->
                <VBox spacing="4">
                    <Label text="Mot de passe"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #424242;"/>
                    <PasswordField fx:id="motDePasseField"
                                   promptText="Minimum 8 caractères, majuscule, chiffre, spécial"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13; -fx-border-color: #E0E0E0;
                                          -fx-border-radius: 8; -fx-border-width: 1.5;"/>
                    <Label fx:id="motDePasseError" text=""
                           style="-fx-font-size: 11; -fx-text-fill: #F44336;"/>
                </VBox>

                <!-- Confirmer mot de passe -->
                <VBox spacing="4">
                    <Label text="Confirmer le mot de passe"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #424242;"/>
                    <PasswordField fx:id="confirmMotDePasseField"
                                   promptText="Répétez votre mot de passe"
                                   style="-fx-background-radius: 8; -fx-padding: 10;
                                          -fx-font-size: 13; -fx-border-color: #E0E0E0;
                                          -fx-border-radius: 8; -fx-border-width: 1.5;"/>
                    <Label fx:id="confirmMotDePasseError" text=""
                           style="-fx-font-size: 11; -fx-text-fill: #F44336;"/>
                </VBox>

                <!-- Message erreur global -->
                <Label fx:id="inscriptionError" text=""
                       wrapText="true"
                       style="-fx-font-size: 12; -fx-text-fill: #F44336;
                              -fx-background-color: #FFEBEE; -fx-background-radius: 8;
                              -fx-padding: 8 12 8 12;"/>

                <!-- Bouton inscription -->
                <Button text="S'inscrire" onAction="#sInscrire"
                        prefWidth="348" prefHeight="44"
                        style="-fx-background-color: #2979FF; -fx-text-fill: white;
                               -fx-font-size: 14; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-cursor: hand;"/>

                <!-- Lien retour login -->
                <HBox alignment="CENTER">
                    <Label text="Déjà un compte ? "
                           style="-fx-font-size: 12; -fx-text-fill: #9E9E9E;"/>
                    <Label text="Se connecter"
                           onMouseClicked="#allerVersLogin"
                           style="-fx-font-size: 12; -fx-text-fill: #2979FF;
                                  -fx-cursor: hand; -fx-underline: true;"/>
                </HBox>

                <!-- Footer -->
                <Label text="StudyFlow © 2026"
                       style="-fx-font-size: 11; -fx-text-fill: #9E9E9E;"/>

            </VBox>
        </VBox>
    </HBox>
</StackPane>