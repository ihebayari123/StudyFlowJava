<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.StressChatbotController"
      style="-fx-background-color: #1a1a2e;">

    <!-- ═══════════════════════ SIDEBAR CHAT ═══════════════════════ -->
    <VBox prefWidth="260" minWidth="260"
          style="-fx-background-color: #16213e; -fx-padding: 0;">

        <!-- Header sidebar -->
        <VBox spacing="8" alignment="CENTER"
              style="-fx-background-color: #0f3460; -fx-padding: 20 16 16 16;">
            <Circle radius="28" style="-fx-fill: #6a1b9a;"/>
            <Label text="🤖 Assistant Stress"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-text-fill: white; -fx-font-family: 'Segoe UI';"/>
            <Label text="Analyse IA en temps réel"
                   style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.6);
                          -fx-font-family: 'Segoe UI';"/>
        </VBox>

        <!-- Statut -->
        <VBox spacing="6" style="-fx-padding: 14 16;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Circle fx:id="statusDot" radius="5" style="-fx-fill: #4caf50;"/>
                <Label fx:id="statusLabel" text="En ligne"
                       style="-fx-font-size: 11px; -fx-text-fill: #4caf50;
                              -fx-font-family: 'Segoe UI';"/>
            </HBox>
        </VBox>

        <Separator style="-fx-background-color: rgba(255,255,255,0.1);"/>

        <!-- Étapes du processus -->
        <VBox spacing="0" style="-fx-padding: 14 0;">
            <Label text="ÉTAPES"
                   style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.4);
                          -fx-padding: 0 16 8 16; -fx-font-family: 'Segoe UI';"/>

            <HBox fx:id="step1Box" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 10 16; -fx-background-color: rgba(106,27,154,0.3);">
                <Label fx:id="step1Icon" text="1"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: white; -fx-background-color: #6a1b9a;
                              -fx-background-radius: 50%; -fx-min-width: 22;
                              -fx-min-height: 22; -fx-alignment: CENTER;"/>
                <Label text="Score de bien-être"
                       style="-fx-font-size: 11px; -fx-text-fill: white;
                              -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <HBox fx:id="step2Box" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 10 16;">
                <Label fx:id="step2Icon" text="2"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: rgba(255,255,255,0.4);
                              -fx-background-color: rgba(255,255,255,0.1);
                              -fx-background-radius: 50%; -fx-min-width: 22;
                              -fx-min-height: 22; -fx-alignment: CENTER;"/>
                <Label text="Votre nom"
                       style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.5);
                              -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <HBox fx:id="step3Box" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 10 16;">
                <Label fx:id="step3Icon" text="3"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: rgba(255,255,255,0.4);
                              -fx-background-color: rgba(255,255,255,0.1);
                              -fx-background-radius: 50%; -fx-min-width: 22;
                              -fx-min-height: 22; -fx-alignment: CENTER;"/>
                <Label text="Capture visage"
                       style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.5);
                              -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <HBox fx:id="step4Box" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 10 16;">
                <Label fx:id="step4Icon" text="4"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: rgba(255,255,255,0.4);
                              -fx-background-color: rgba(255,255,255,0.1);
                              -fx-background-radius: 50%; -fx-min-width: 22;
                              -fx-min-height: 22; -fx-alignment: CENTER;"/>
                <Label text="Analyse stress IA"
                       style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.5);
                              -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <HBox fx:id="step5Box" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 10 16;">
                <Label fx:id="step5Icon" text="5"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: rgba(255,255,255,0.4);
                              -fx-background-color: rgba(255,255,255,0.1);
                              -fx-background-radius: 50%; -fx-min-width: 22;
                              -fx-min-height: 22; -fx-alignment: CENTER;"/>
                <Label text="PDF &amp; Emploi du temps"
                       style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.5);
                              -fx-font-family: 'Segoe UI';"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- Photo capturée -->
        <VBox fx:id="photoPreviewBox" spacing="6" alignment="CENTER"
              visible="false" managed="false"
              style="-fx-padding: 12 16; -fx-background-color: rgba(255,255,255,0.05);
                     -fx-background-radius: 10; -fx-margin: 10;">
            <Label text="📸 Photo capturée"
                   style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.6);"/>
            <ImageView fx:id="photoPreview"
                       fitWidth="120" fitHeight="120" preserveRatio="true"/>
            <Label fx:id="capturedNameLabel" text=""
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #ff5252; -fx-font-family: 'Segoe UI';"/>
        </VBox>

        <!-- Bouton télécharger PDF -->
        <VBox fx:id="downloadBox" spacing="8" alignment="CENTER"
              visible="false" managed="false"
              style="-fx-padding: 12 16;">
            <Button fx:id="btnDownloadPdf" text="⬇  Télécharger le PDF"
                    onAction="#downloadPdf"
                    maxWidth="Infinity"
                    style="-fx-background-color: #6a1b9a; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 10;
                           -fx-padding: 10 16; -fx-cursor: hand;
                           -fx-font-family: 'Segoe UI'; -fx-font-size: 12px;
                           -fx-effect: dropshadow(gaussian, rgba(106,27,154,0.4), 8, 0, 0, 2);"/>
        </VBox>
    </VBox>

    <!-- ═══════════════════════ ZONE CHAT ═══════════════════════════ -->
    <VBox HBox.hgrow="ALWAYS"
          style="-fx-background-color: #1a1a2e;">

        <!-- Header chat -->
        <HBox prefHeight="60" alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #0f3460; -fx-padding: 0 20;">
            <Label text="🧠"  style="-fx-font-size: 22px;"/>
            <VBox spacing="2">
                <Label text="Analyse de Stress — IA"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;
                              -fx-text-fill: white; -fx-font-family: 'Segoe UI';"/>
                <Label text="Modèle RandomForest — Précision 88.8%"
                       style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.5);
                              -fx-font-family: 'Segoe UI';"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="predictionBadge" text=""
                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                          -fx-padding: 5 14; -fx-background-radius: 20;
                          -fx-font-family: 'Segoe UI';"/>
        </HBox>

        <!-- Messages -->
        <ScrollPane fx:id="chatScrollPane" VBox.vgrow="ALWAYS"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox fx:id="chatMessages" spacing="12"
                  style="-fx-padding: 20; -fx-background-color: #1a1a2e;">
            </VBox>
        </ScrollPane>

        <!-- Indicateur de frappe -->
        <HBox fx:id="typingIndicator" spacing="6" alignment="CENTER_LEFT"
              visible="false" managed="false"
              style="-fx-padding: 4 24;">
            <Label text="🤖 L'assistant analyse..."
                   style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.4);
                          -fx-font-style: italic;"/>
        </HBox>

        <!-- Zone de saisie -->
        <HBox spacing="10" alignment="CENTER"
              style="-fx-background-color: #16213e; -fx-padding: 12 16;">
            <TextField fx:id="inputField"
                       HBox.hgrow="ALWAYS"
                       promptText="Tapez votre réponse..."
                       onAction="#sendMessage"
                       style="-fx-background-color: #0f3460;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: rgba(255,255,255,0.3);
                              -fx-border-color: rgba(106,27,154,0.5);
                              -fx-border-radius: 20; -fx-background-radius: 20;
                              -fx-padding: 10 16; -fx-font-size: 13px;
                              -fx-font-family: 'Segoe UI';"/>
            <Button fx:id="btnSend" text="➤" onAction="#sendMessage"
                    style="-fx-background-color: #6a1b9a; -fx-text-fill: white;
                           -fx-font-size: 16px; -fx-background-radius: 50%;
                           -fx-min-width: 42; -fx-min-height: 42;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(106,27,154,0.4), 6, 0, 0, 1);"/>
        </HBox>
    </VBox>
</HBox>
