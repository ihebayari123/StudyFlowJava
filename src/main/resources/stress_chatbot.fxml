<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.TextAlignment?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.connexion3a36.Controller.StressChatbotController"
           style="-fx-background-color: linear-gradient(to bottom, #fce4ec, #f8bbd0);">

    <!-- Top Section - Title -->
    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
            <Label text="Chatbot - Calcul du Stress"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #c2185b;"/>
            <Label text="Repondez aux questions pour calculer votre niveau de stress"
                   style="-fx-font-size: 14px; -fx-text-fill: #d81b60;"/>
        </VBox>
    </top>

    <!-- Center Section - Chat Area -->
    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20;">

            <!-- Chat Display Area -->
            <ScrollPane style="-fx-padding: 10;">
                <TextArea fx:id="chatArea"
                         editable="false"
                         prefWidth="550" prefHeight="280"
                         wrapText="true"
                         style="-fx-font-size: 14px; -fx-text-fill: #333; -fx-background-color: white; -fx-border-color: #f48fb1; -fx-border-radius: 10;"/>
            </ScrollPane>

            <!-- Question Display -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 15;">
                <Label fx:id="questionLabel"
                       text="Appuyez sur 'Demarrer' pour commencer"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ad1457;"
                       textAlignment="CENTER"
                       wrapText="true"/>
            </VBox>

            <!-- Answer Input -->
            <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10;">
                <TextField fx:id="answerField"
                         prefWidth="350" prefHeight="45"
                         promptText="Entrez votre reponse ici..."
                         style="-fx-font-size: 16px;"/>
                <Button fx:id="btnSubmit"
                        text="Valider"
                        onAction="#submitAnswer"
                        prefWidth="120" prefHeight="45"
                        disable="true"
                        style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #d81b60; -fx-background-radius: 25;"/>
            </HBox>

            <!-- Progress -->
            <Label fx:id="progressLabel"
                   text="Question: 0 / 5"
                   style="-fx-font-size: 14px; -fx-text-fill: #880e4f;"/>

            <!-- Result Display -->
            <VBox alignment="CENTER" spacing="10" fx:id="resultBox" visible="false">
                <Label text="Votre niveau de stress:"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #c2185b;"/>
                <Label fx:id="resultLabel"
                       text=""
                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #ad1457;"
                       textAlignment="CENTER"/>
                <Label fx:id="resultDescription"
                       text=""
                       style="-fx-font-size: 16px; -fx-text-fill: #333;"
                       textAlignment="CENTER"
                       wrapText="true"/>
            </VBox>

        </VBox>
    </center>

    <!-- Bottom Section - Control Buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="30" style="-fx-padding: 20;">
            <Button fx:id="btnStart"
                    text="Demarrer"
                    onAction="#startChat"
                    prefWidth="150" prefHeight="45"
                    style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #ec407a; -fx-background-radius: 25;"/>
            <Button fx:id="btnReset"
                    text="Recommencer"
                    onAction="#resetChat"
                    prefWidth="150" prefHeight="45"
                    disable="true"
                    style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #ab47bc; -fx-background-radius: 25;"/>
            <Button fx:id="btnBack"
                    text="Retour"
                    onAction="#goBack"
                    prefWidth="150" prefHeight="45"
                    style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #78909c; -fx-background-radius: 25;"/>
        </HBox>
    </bottom>

</BorderPane>