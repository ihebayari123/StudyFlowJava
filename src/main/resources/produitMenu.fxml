<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #F5F6FA;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.ProduitMenuController">

    <VBox spacing="8">
        <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="🛒 Produits" />
        <Label style="-fx-font-size: 14; -fx-text-fill: #757575;" text="Gérer les produits" />
    </VBox>

    <HBox fx:id="afficherBtn" alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2); -fx-cursor: hand;">
        <Label style="-fx-font-size: 28;" text="📋" />
        <VBox>
            <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Afficher les produits" />
            <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="Voir, modifier et supprimer" />
        </VBox>
        <Label style="-fx-font-size: 16; -fx-text-fill: #9E9E9E;" text="→" />
    </HBox>

    <HBox fx:id="ajouterBtn" alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2); -fx-cursor: hand;">
        <Label style="-fx-font-size: 28;" text="➕" />
        <VBox>
            <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Ajouter un produit" />
            <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="Créer un nouveau produit" />
        </VBox>
        <Label style="-fx-font-size: 16; -fx-text-fill: #9E9E9E;" text="→" />
    </HBox>

</VBox>