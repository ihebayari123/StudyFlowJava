<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #c8d8e8;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a36.Controller.AfficherPersonneController">

    <children>
        <!-- Rectangle de fond avec dégradé bleu -->
        <Rectangle height="400" style="-fx-fill: linear-gradient(to bottom right, #7BAFD4, #B0C9D8, #8A9BAA);" width="600" />

        <!-- Carte principale centrée -->
        <VBox alignment="CENTER" layoutX="25" layoutY="25" prefWidth="550" prefHeight="350">

            <VBox prefHeight="350" prefWidth="550"
                  style="-fx-background-color: #F5F6FA; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 8); -fx-padding: 20 25 20 25;"
                  spacing="15">

                <!-- Header avec titre -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Rectangle height="24" width="4" style="-fx-fill: #2979FF; -fx-arc-width: 2; -fx-arc-height: 2;" />
                    <Label text="Liste des Personnes"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
                </HBox>

                <Separator style="-fx-background-color: #E0E0E0;" />

                <!-- Label d'information -->
                <Label fx:id="labelInfo" text="Informations"
                       style="-fx-font-size: 12px; -fx-text-fill: #757575; -fx-font-family: 'Segoe UI'; -fx-padding: 0 0 0 4;"/>

                <!-- TableView moderne -->
                <TableView fx:id="tablepersonne" prefHeight="200" prefWidth="500"
                           style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12; -fx-border-width: 1;">
                    <columns>
                        <TableColumn fx:id="nomcol" prefWidth="245" text="Nom"
                                     style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI'; -fx-alignment: CENTER_LEFT;"/>
                        <TableColumn fx:id="prenomcol" prefWidth="245" text="Prénom"
                                     style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI'; -fx-alignment: CENTER_LEFT;"/>
                    </columns>
                </TableView>

                <!-- Footer avec indicateur de statut -->
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Rectangle height="8" width="8" style="-fx-fill: #4CAF50; -fx-arc-width: 4; -fx-arc-height: 4;" />
                    <Label text="Données à jour"
                           style="-fx-font-size: 10px; -fx-text-fill: #9E9E9E; -fx-font-family: 'Segoe UI';"/>
                </HBox>

            </VBox>
        </VBox>
    </children>
</AnchorPane>