<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ProgressBar?>

<AnchorPane prefHeight="620.0" prefWidth="580.0" style="-fx-background-color: #c8d8e8;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a36.Controller.AfficherMedecinController">

    <children>
        <!-- Rectangle de fond avec dégradé bleu -->
        <Rectangle height="620" style="-fx-fill: linear-gradient(to bottom right, #7BAFD4, #B0C9D8, #8A9BAA);" width="580" />

        <VBox alignment="CENTER" layoutX="15" layoutY="15" prefWidth="550" prefHeight="590">

            <VBox prefHeight="590" prefWidth="550" style="-fx-background-color: #F5F6FA; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 8);">

                <HBox VBox.vgrow="ALWAYS">

                    <!-- ======================== SIDEBAR ======================== -->
                    <VBox prefWidth="180" spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16 0 0 16; -fx-padding: 20 0 20 0;">

                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 16 16 20;">
                            <Circle radius="14" style="-fx-fill: #2979FF;" />
                            <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-padding: 0 0 0 8;" text="EduDoc" />
                        </HBox>

                        <VBox style="-fx-padding: 0 16 20 20; -fx-spacing: 4;">
                            <Label style="-fx-font-size: 10; -fx-text-fill: #9E9E9E;" text="Gestion Médicale" />
                            <HBox alignment="CENTER_LEFT" spacing="4">
                                <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2979FF;" text="Liste" />
                                <Label style="-fx-font-size: 10; -fx-text-fill: #9E9E9E;" text="des médecins" />
                            </HBox>
                            <ProgressBar prefHeight="5" prefWidth="120" progress="0.8" style="-fx-accent: #2979FF; -fx-background-color: #E0E0E0; -fx-background-radius: 4;" />
                        </VBox>

                        <Separator style="-fx-background-color: #F0F0F0;" />

                        <VBox spacing="8" style="-fx-padding: 16 12 0 12;">
                            <Label style="-fx-font-size: 10; -fx-text-fill: #9E9E9E; -fx-padding: 0 0 4 8;" text="RÉSUMÉ" />

                            <!-- Total Médecins -->
                            <VBox spacing="4" style="-fx-background-color: #E8F0FE; -fx-background-radius: 10; -fx-padding: 12;">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 14;" text="👨‍⚕️" />
                                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #2979FF;" text="Total Médecins" />
                                </HBox>
                                <Label fx:id="totalDoctorsLabel" text="0"
                                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-padding: 0 0 0 4;"/>
                            </VBox>

                            <!-- Disponibilité -->
                            <VBox spacing="4" style="-fx-background-color: #F5F5F5; -fx-background-radius: 10; -fx-padding: 12;">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 14;" text="📊" />
                                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Disponibilité" />
                                </HBox>
                                <Label fx:id="availableDoctorsLabel" text="0 disponible(s)"
                                       style="-fx-font-size: 12; -fx-text-fill: #757575; -fx-padding: 0 0 0 4;"/>
                            </VBox>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <!-- Badge médecin -->
                        <VBox alignment="CENTER" spacing="4" style="-fx-padding: 16;">
                            <Label text="MÉDECIN"
                                   style="-fx-font-size: 9px; -fx-text-fill: #2979FF; -fx-font-weight: bold;"/>
                            <Label text="🩺" style="-fx-font-size: 24px;"/>
                            <Label text="Service de santé"
                                   style="-fx-font-size: 9px; -fx-text-fill: #9E9E9E;"/>
                        </VBox>
                    </VBox>

                    <!-- ======================== TABLEAU ======================== -->
                    <VBox prefWidth="370" spacing="14" style="-fx-background-color: #F5F6FA; -fx-background-radius: 0 16 16 0; -fx-padding: 20 20 20 20;">

                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Rectangle height="24" width="4" style="-fx-fill: #2979FF; -fx-arc-width: 2; -fx-arc-height: 2;" />
                            <Label text="Liste des Médecins"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
                        </HBox>

                        <Label text="Consultation — Service Médical"
                               style="-fx-font-size: 11px; -fx-text-fill: #9E9E9E; -fx-font-family: 'Segoe UI';"/>

                        <Separator style="-fx-background-color: #E0E0E0;" />

                        <Label text="LISTE DES MÉDECINS"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>

                        <!-- BARRE DE RECHERCHE, FILTRE ET TRI -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="rechercheTF" promptText="🔍 Rechercher par nom..." prefWidth="140"
                                       style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-family: 'Segoe UI'; -fx-font-size: 11px;"/>

                            <ComboBox fx:id="filtreDispoCB" prefWidth="100" promptText="Disponibilité"
                                      style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-family: 'Segoe UI'; -fx-font-size: 11px;"/>

                            <Button fx:id="btnTriAsc" text="⬆ A-Z" onAction="#trierCroissant" prefWidth="60"
                                    style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="btnTriDesc" text="⬇ Z-A" onAction="#trierDecroissant" prefWidth="60"
                                    style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>

                        <!-- TableView -->
                        <TableView fx:id="tableView" prefHeight="340" prefWidth="330"
                                   style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12; -fx-border-width: 1;">
                            <columns>
                                <TableColumn fx:id="colId" text="ID" prefWidth="50"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI'; -fx-alignment: CENTER;"/>
                                <TableColumn fx:id="colNom" text="Nom" prefWidth="130"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>
                                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="130"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="150"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>
                                <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="100"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>
                                <TableColumn fx:id="colDisponibilite" text="Disponibilité" prefWidth="100"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>
                            </columns>
                        </TableView>

                        <!-- Boutons d'action -->
                        <HBox spacing="12" alignment="CENTER_RIGHT">
                            <VBox.margin><Insets top="8"/></VBox.margin>
                            <Button text="🗑️ Supprimer" onAction="#supprimer" prefHeight="38" prefWidth="100"
                                    style="-fx-background-color: #FF5252; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,82,82,0.25), 8, 0, 0, 2);"/>
                            <Button text="✏️ Modifier" onAction="#modifier" prefHeight="38" prefWidth="100"
                                    style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(41,121,255,0.25), 8, 0, 0, 2);"/>
                            <Button text="🔒 Fermer" onAction="#fermer" prefHeight="38" prefWidth="100"
                                    style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575; -fx-font-size: 11px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-background-radius: 10; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>