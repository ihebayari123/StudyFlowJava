<?xml version="1.0" encoding="UTF-8"?>




<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: #F5F6FA;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.ChapitreController">

    <!-- ── Header bar ──────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #FFFFFF; -fx-padding: 16 24; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <Button fx:id="backButton" text="← Retour aux cours"
                onAction="#handleBack"
                style="-fx-background-color: #E8F0FE; -fx-text-fill: #2979FF; -fx-font-weight: bold;
                        -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 14;" />
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="courseTitleLabel"
                   text="📖 Chapitres"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" />
            <Label fx:id="courseSubtitleLabel"
                   text="Cours sélectionné"
                   style="-fx-font-size: 12; -fx-text-fill: #757575;" />
        </VBox>
    </HBox>

    <!-- ── Toolbar ────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding: 14 24; -fx-background-color: #FAFAFA; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher un chapitre..."
                   prefWidth="280"
                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 8 12;" />
        <Button text="Rechercher" onAction="#handleSearch"
                style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-cursor: hand;
                        -fx-background-radius: 8; -fx-padding: 8 16;" />
        <Button text="Tout afficher" onAction="#handleShowAll"
                style="-fx-background-color: #E0E0E0; -fx-text-fill: #333; -fx-cursor: hand;
                        -fx-background-radius: 8; -fx-padding: 8 16;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="statusLabel" text="Chargement..."
               style="-fx-text-fill: #9E9E9E; -fx-font-size: 12;" />
        <Button fx:id="addChapitreBtn" text="➕  Ajouter un chapitre"
                onAction="#handleAddChapitre"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;
                        -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 16;" />
    </HBox>

    <!-- ── Table ──────────────────────────────────────────────────── -->
    <!-- ── Table ──────────────────────────────────────────────────── -->
    <TableView fx:id="chapitresTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: transparent;">

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>

        <columns>
            <TableColumn fx:id="idColumn"          text="ID"          prefWidth="50"  />
            <TableColumn fx:id="ordreColumn"       text="Ordre"       prefWidth="60"  />
            <TableColumn fx:id="titreColumn"       text="Titre"       prefWidth="200" />
            <TableColumn fx:id="contenuColumn"     text="Contenu"     prefWidth="260" />
            <TableColumn fx:id="contentTypeColumn" text="Type"        prefWidth="80"  />
            <TableColumn fx:id="durationColumn"    text="Durée (min)" prefWidth="90"  />
            <TableColumn fx:id="actionsColumn"     text="Actions"     prefWidth="200" />
        </columns>

        <placeholder>
            <Label text="Aucun chapitre pour ce cours. Cliquez sur « Ajouter » pour commencer."
                   style="-fx-text-fill: #9E9E9E; -fx-font-size: 13;" />
        </placeholder>
    </TableView>

</VBox>

