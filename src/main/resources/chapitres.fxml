<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.Controller.ChapitreController">

    <VBox spacing="8">
        <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="📖 Chapitres" />
        <Label style="-fx-font-size: 14; -fx-text-fill: #757575;" text="Programmation Java" />
    </VBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="12">

            <HBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 16; -fx-cursor: hand;">
                <StackPane prefHeight="40" prefWidth="40" style="-fx-background-color: #E8F0FE; -fx-background-radius: 8;">
                    <Label style="-fx-font-size: 18;" text="1" />
                </StackPane>
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Introduction à Java" />
                    <Label style="-fx-font-size: 11; -fx-text-fill: #757575;" text="Durée: 45 min · Quiz: 5 questions" />
                </VBox>
                <Label style="-fx-font-size: 16; -fx-text-fill: #4CAF50;" text="✓" />
            </HBox>

            <HBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 16; -fx-cursor: hand;">
                <StackPane prefHeight="40" prefWidth="40" style="-fx-background-color: #E8F0FE; -fx-background-radius: 8;">
                    <Label style="-fx-font-size: 18;" text="2" />
                </StackPane>
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Variables et Types" />
                    <Label style="-fx-font-size: 11; -fx-text-fill: #757575;" text="Durée: 60 min · Quiz: 8 questions" />
                </VBox>
                <Label style="-fx-font-size: 16; -fx-text-fill: #9E9E9E;" text="⏳" />
            </HBox>

            <HBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 16; -fx-cursor: hand;">
                <StackPane prefHeight="40" prefWidth="40" style="-fx-background-color: #E8F0FE; -fx-background-radius: 8;">
                    <Label style="-fx-font-size: 18;" text="3" />
                </StackPane>
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Structures de contrôle" />
                    <Label style="-fx-font-size: 11; -fx-text-fill: #757575;" text="Durée: 75 min · Quiz: 10 questions" />
                </VBox>
                <Label style="-fx-font-size: 16; -fx-text-fill: #9E9E9E;" text="🔒" />
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>