<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.connexion3a36.controllers.EventController"
      spacing="0"
      style="-fx-background-color: #f0f4f8;">

    <!-- ── HEADER ── -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: linear-gradient(to right, #2979FF, #1565C0);
                 -fx-padding: 18 28 18 28;">
        <Button text="← Retour" onAction="#handleRetour"
                style="-fx-background-color: rgba(255,255,255,0.15);
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-font-size: 12px; -fx-padding: 7 16;
                       -fx-background-radius: 20; -fx-cursor: hand;
                       -fx-border-color: rgba(255,255,255,0.4);
                       -fx-border-radius: 20;"/>
        <Label text="🎉 Gestion des Événements"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;">

        <VBox spacing="20" style="-fx-padding: 24 28 28 28; -fx-background-color: #f0f4f8;">

            <!-- ── FORMULAIRE ── -->
            <VBox spacing="14"
                  style="-fx-background-color: white; -fx-padding: 22;
                         -fx-background-radius: 14;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4);">

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📝" style="-fx-font-size: 16px;"/>
                    <Label text="Formulaire"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </HBox>

                <Region prefHeight="1" style="-fx-background-color: #f0f0f0;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Titre *"
                               style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="titreField"
                                   promptText="Titre de l'événement"
                                   style="-fx-pref-height: 38; -fx-background-radius: 8;
                                          -fx-border-color: #e0e0e0; -fx-border-radius: 8;
                                          -fx-padding: 0 12; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Type *"
                               style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="typeCombo" promptText="Choisir un type"
                                  style="-fx-pref-width: 180; -fx-pref-height: 38;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Date *"
                               style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <DatePicker fx:id="datePicker" style="-fx-pref-width: 180; -fx-pref-height: 38;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Description *"
                               style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextArea fx:id="descriptionArea"
                                  promptText="Description de l'événement"
                                  prefHeight="90" wrapText="true"
                                  style="-fx-background-radius: 8; -fx-border-color: #e0e0e0;
                                         -fx-border-radius: 8; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" minWidth="220">
                        <Label text="Image"
                               style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="imageField" promptText="Aucune image choisie"
                                       style="-fx-pref-width: 130; -fx-pref-height: 38;
                                              -fx-background-radius: 8; -fx-border-color: #e0e0e0;
                                              -fx-border-radius: 8;" editable="false"/>
                            <Button text="📁 Parcourir" onAction="#handleChoisirImage"
                                    style="-fx-background-color: #6c757d; -fx-text-fill: white;
                                           -fx-font-size: 12px; -fx-pref-height: 38;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>
                        <ImageView fx:id="imagePreview" fitWidth="80" fitHeight="55" preserveRatio="true"/>
                        <Label text="User ID *"
                               style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="userIdField" promptText="ID utilisateur"
                                   style="-fx-pref-width: 220; -fx-pref-height: 38;
                                          -fx-background-radius: 8; -fx-border-color: #e0e0e0;
                                          -fx-border-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="btnAjouter" text="➕ Ajouter" onAction="#handleAjouter"
                            style="-fx-background-color: #2979FF; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-pref-width: 120; -fx-pref-height: 40;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="btnModifier" text="✏️ Modifier" onAction="#handleModifier"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-pref-width: 120; -fx-pref-height: 40;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="btnSupprimer" text="🗑️ Supprimer" onAction="#handleSupprimer"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-pref-width: 130; -fx-pref-height: 40;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="btnVider" text="🔄 Vider" onAction="#handleVider"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-pref-width: 100; -fx-pref-height: 40;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <Label fx:id="messageLabel" text=""
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- ══════════════════════════════════════
                 TABLEAU OPTIMISÉ
            ══════════════════════════════════════ -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-padding: 22;
                         -fx-background-radius: 14;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4);">

                <!-- Header tableau avec compteur -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📋" style="-fx-font-size: 16px;"/>
                    <Label text="Liste des Événements"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                </HBox>

                <Region prefHeight="1" style="-fx-background-color: #eef0f4;"/>

                <TableView fx:id="eventTable" VBox.vgrow="ALWAYS" prefHeight="380"
                           style="-fx-background-color: transparent;
                                  -fx-border-color: transparent;
                                  -fx-background-radius: 10;
                                  -fx-padding: 0;
                                  -fx-table-cell-border-color: #f0f4f8;
                                  -fx-selection-bar: #E8F0FE;
                                  -fx-selection-bar-non-focused: #EEF2FF;
                                  -fx-focus-color: transparent;
                                  -fx-faint-focus-color: transparent;">
                    <columns>
                        <!-- ID -->
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"
                                     style="-fx-alignment: CENTER;"/>

                        <!-- IMAGE -->
                        <TableColumn fx:id="colImage" text="Image" prefWidth="90"
                                     style="-fx-alignment: CENTER;"/>

                        <!-- TITRE -->
                        <TableColumn fx:id="colTitre" text="Titre" prefWidth="170"
                                     style="-fx-alignment: CENTER_LEFT;"/>

                        <!-- TYPE -->
                        <TableColumn fx:id="colType" text="Type" prefWidth="110"
                                     style="-fx-alignment: CENTER;"/>

                        <!-- DATE -->
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120"
                                     style="-fx-alignment: CENTER;"/>

                        <!-- DESCRIPTION -->
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="230"
                                     style="-fx-alignment: CENTER_LEFT;"/>

                        <!-- USER ID -->
                        <TableColumn fx:id="colUserId" text="User" prefWidth="60"
                                     style="-fx-alignment: CENTER;"/>
                    </columns>

                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <Label text="📭"
                                   style="-fx-font-size: 36px;"/>
                            <Label text="Aucun événement trouvé"
                                   style="-fx-text-fill: #aaa; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                            <Label text="Ajoutez votre premier événement ci-dessus"
                                   style="-fx-text-fill: #ccc; -fx-font-size: 12px;"/>
                        </VBox>
                    </placeholder>
                </TableView>

            </VBox>

        </VBox>
    </ScrollPane>
</VBox>