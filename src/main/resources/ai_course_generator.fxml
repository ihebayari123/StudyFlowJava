<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.AiCourseGeneratorController"
      spacing="0"
      style="-fx-background-color: #F5F6FA;">

    <!-- ══ HEADER ══════════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: #FFFFFF; -fx-padding: 16 24;
                 -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">

        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="🤖 Générateur de Cours IA"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"/>
            <Label text="Génère automatiquement cours + chapitres avec votre modèle Ollama local"
                   style="-fx-font-size: 12; -fx-text-fill: #757575;"/>
        </VBox>

        <VBox alignment="CENTER_RIGHT" spacing="4">
            <Label fx:id="ollamaStatusLabel" text="🔄 Vérification..."
                   style="-fx-font-size: 12; -fx-text-fill: #9E9E9E;"/>
            <Button text="🔄 Vérifier Ollama" onAction="#handleRefreshOllama"
                    style="-fx-background-color: #E8F0FE; -fx-text-fill: #2979FF;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 10;"/>
        </VBox>
    </HBox>

    <!-- ══ BODY ════════════════════════════════════════════════════════════════ -->
    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- ── LEFT PANEL : Configuration ──────────────────────────────────── -->
        <VBox spacing="16" prefWidth="320" minWidth="300"
              style="-fx-background-color: #FFFFFF; -fx-padding: 20;
                     -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">

            <Label text="⚙️ Configuration"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"/>

            <!-- Model -->
            <VBox spacing="4">
                <Label text="Modèle Ollama" style="-fx-font-weight: bold; -fx-text-fill: #444;"/>
                <ComboBox fx:id="modelComboBox" prefWidth="Infinity"
                          style="-fx-background-radius: 6; -fx-padding: 4 8;"/>
            </VBox>

            <!-- Subject -->
            <VBox spacing="4">
                <Label text="Sujet du cours *" style="-fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="subjectField"
                           promptText="ex: Python pour débutants, HTML/CSS, Machine Learning..."
                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;"/>
            </VBox>

            <!-- Level -->
            <VBox spacing="4">
                <Label text="Niveau" style="-fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="levelField"
                           promptText="débutant / intermédiaire / avancé"
                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;"/>
            </VBox>

            <!-- Chapters count -->
            <VBox spacing="4">
                <Label text="Nombre de chapitres" style="-fx-font-weight: bold; -fx-text-fill: #444;"/>
                <Spinner fx:id="chaptersSpinner" prefWidth="Infinity"
                         style="-fx-background-radius: 6;"/>
            </VBox>

            <Separator/>

            <!-- Options -->
            <Label text="📎 Options de contenu"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <CheckBox fx:id="includeVideosCheck"
                      text="🎥 Inclure des liens vidéo YouTube"
                      selected="true"
                      style="-fx-text-fill: #333;"/>
            <CheckBox fx:id="includeResourcesCheck"
                      text="🔗 Inclure des ressources web"
                      selected="true"
                      style="-fx-text-fill: #333;"/>
            <CheckBox fx:id="saveToDbCheck"
                      text="💾 Auto-sauvegarder après génération"
                      selected="false"
                      style="-fx-text-fill: #333;"/>

            <Separator/>

            <!-- Actions -->
            <Button fx:id="generateButton" text="🚀  Générer avec l'IA"
                    onAction="#handleGenerate"
                    prefWidth="Infinity" prefHeight="42"
                    style="-fx-background-color: #2979FF; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 14;
                           -fx-cursor: hand; -fx-background-radius: 8;"/>

            <HBox spacing="8">
                <Button fx:id="saveButton" text="💾 Sauvegarder"
                        onAction="#handleSave"
                        HBox.hgrow="ALWAYS" prefHeight="36"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 8;"/>
                <Button fx:id="clearButton" text="🗑️ Effacer"
                        onAction="#handleClear"
                        prefHeight="36"
                        style="-fx-background-color: #E0E0E0; -fx-text-fill: #333;
                               -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 0 14;"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Tips -->
            <VBox spacing="6"
                  style="-fx-background-color: #FFF8E1; -fx-background-radius: 8;
                         -fx-padding: 12; -fx-border-color: #FFE082;
                         -fx-border-radius: 8; -fx-border-width: 1;">
                <Label text="💡 Conseils"
                       style="-fx-font-weight: bold; -fx-text-fill: #F57F17; -fx-font-size: 12;"/>
                <Label text="• phi3:latest → plus rapide"
                       style="-fx-text-fill: #555; -fx-font-size: 11;"/>
                <Label text="• gemma:2b → bon équilibre"
                       style="-fx-text-fill: #555; -fx-font-size: 11;"/>
                <Label text="• Ollama doit être lancé: ollama serve"
                       style="-fx-text-fill: #555; -fx-font-size: 11; -fx-wrap-text: true;"/>
            </VBox>
        </VBox>

        <!-- ── RIGHT PANEL : Output ─────────────────────────────────────────── -->
        <VBox spacing="12" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">

            <!-- Status bar -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <ProgressIndicator fx:id="progressIndicator" prefWidth="20" prefHeight="20"/>
                <Label fx:id="statusLabel" text="Prêt — configurez et cliquez sur Générer"
                       style="-fx-text-fill: #757575; -fx-font-size: 12;"/>
            </HBox>

            <!-- Generated course preview -->
            <VBox spacing="8"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 10;
                         -fx-padding: 16; -fx-border-color: #E0E0E0;
                         -fx-border-radius: 10; -fx-border-width: 1;">

                <Label text="📚 Aperçu du cours généré"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Titre :"
                           style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-min-width: 80;"/>
                    <Label fx:id="generatedTitleLabel" text="—"
                           style="-fx-text-fill: #1A1A2E; -fx-font-size: 13; -fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="8" alignment="TOP_LEFT">
                    <Label text="Description :"
                           style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-min-width: 80;"/>
                    <Label fx:id="generatedDescLabel" text="—"
                           style="-fx-text-fill: #444; -fx-wrap-text: true;"
                           HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Chapters table -->
            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Label text="📖 Chapitres générés"
                       style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"/>

                <TableView fx:id="previewTable" VBox.vgrow="ALWAYS"
                           columnResizePolicy="$TableView.CONSTRAINED_RESIZE_POLICY"
                           style="-fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="orderCol" text="#"       prefWidth="40"/>
                        <TableColumn fx:id="titleCol" text="Titre"   prefWidth="300"/>
                        <TableColumn fx:id="typeCol"  text="Type"    prefWidth="80"/>
                        <TableColumn fx:id="durationCol" text="Durée (min)" prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="Les chapitres générés apparaîtront ici."
                               style="-fx-text-fill: #9E9E9E;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Raw output -->
            <TitledPane text="🔍 Réponse brute de l'IA (JSON)" expanded="false"
                        style="-fx-background-radius: 8;">
                <TextArea fx:id="rawOutputArea"
                          prefHeight="180" wrapText="true" editable="false"
                          style="-fx-font-family: 'Monospaced'; -fx-font-size: 11;
                                 -fx-background-color: #1E1E1E; -fx-text-fill: #D4D4D4;"/>
            </TitledPane>

        </VBox>
    </HBox>
</VBox>
