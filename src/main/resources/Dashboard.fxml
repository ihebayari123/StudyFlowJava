<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.DashboardController"
      prefWidth="1200" prefHeight="720"
      style="-fx-background-color: #f5f5f5;">

    <!-- ===================== SIDEBAR ===================== -->
    <VBox prefWidth="90" minWidth="90"
          style="-fx-background-color: #111111; -fx-background-radius: 0 20 20 0;">
        <padding><Insets top="30" bottom="30" left="20" right="20"/></padding>
        <spacing>30</spacing>

        <!-- Logo -->
        <Label text="F."
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Georgia';"/>

        <VBox spacing="24" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">
            <!-- Home Icon -->
            <Button fx:id="btnHome" styleClass="sidebar-btn"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="🏠"
                    style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
            <!-- Courses Icon -->
            <Button fx:id="btnCourses"
                    style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: hand;"
                    text="🎓"/>
            <!-- Profile Icon -->
            <Button fx:id="btnProfile"
                    style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: hand;"
                    text="👤"/>
            <!-- Messages Icon -->
            <Button fx:id="btnMessages"
                    style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: hand;"
                    text="✉"/>
            <!-- Settings Icon -->
            <Button fx:id="btnSettings"
                    style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: hand;"
                    text="⚙"/>
        </VBox>

        <!-- Logout Icon -->
        <Button fx:id="btnLogout"
                style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: #888888; -fx-cursor: hand;"
                text="🚪"/>
    </VBox>

    <!-- ===================== MAIN CONTENT ===================== -->
    <VBox HBox.hgrow="ALWAYS" spacing="16">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- TOP ROW: Welcome Card + Stats + Search -->
        <HBox spacing="16" alignment="CENTER_LEFT">

            <!-- Welcome Card -->
            <HBox prefWidth="340" prefHeight="130"
                  style="-fx-background-color: #eeeeee; -fx-background-radius: 18; -fx-alignment: CENTER_LEFT;"
                  alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="20" right="20" bottom="20" left="24"/></padding>
                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Hello Josh!"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                    <Label text="It's good to see you again."
                           style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                </VBox>
                <!-- Illustration placeholder -->
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="👋🧑" style="-fx-font-size: 48px;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Search bar -->
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <TextField fx:id="searchField" promptText="Search..."
                           prefWidth="200" prefHeight="36"
                           style="-fx-background-radius: 20; -fx-background-color: white;
                                  -fx-border-color: #dddddd; -fx-border-radius: 20;
                                  -fx-padding: 6 14; -fx-font-size: 13px;"/>
                <!-- Notification Bell -->
                <Label text="🔔" style="-fx-font-size: 18px; -fx-cursor: hand;"/>
                <!-- Avatar -->
                <Circle fx:id="avatarCircle" radius="18"
                        style="-fx-fill: #cccccc;"/>
            </HBox>
        </HBox>

        <!-- Stats Row: Courses Completed + In Progress -->
        <HBox spacing="12">
            <!-- Stat Card: Completed -->
            <HBox prefWidth="170" prefHeight="64"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #eeeeee; -fx-border-radius: 14;"
                  spacing="8" alignment="CENTER_LEFT">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Label fx:id="lblCompleted" text="11"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                <VBox>
                    <Label text="Courses" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                    <Label text="completed" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                </VBox>
            </HBox>

            <!-- Stat Card: In Progress -->
            <HBox prefWidth="170" prefHeight="64"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #eeeeee; -fx-border-radius: 14;"
                  spacing="8" alignment="CENTER_LEFT">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Label fx:id="lblInProgress" text="4"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                <VBox>
                    <Label text="Courses" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                    <Label text="in progress" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                </VBox>
            </HBox>
        </HBox>

        <!-- MIDDLE ROW: Course List + Right Panel -->
        <HBox spacing="16" VBox.vgrow="ALWAYS">

            <!-- LEFT PANEL: Current Course + Courses List -->
            <VBox spacing="14" prefWidth="420" HBox.hgrow="ALWAYS">

                <!-- Current Course Banner -->
                <HBox prefHeight="60"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #eeeeee; -fx-border-radius: 14;"
                      alignment="CENTER_LEFT" spacing="12">
                    <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>

                    <!-- Flag emoji for Spanish -->
                    <Label text="🇪🇸" style="-fx-font-size: 24px;"/>

                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Spanish B2"
                               style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                        <Label text="by Alejandro Velazquez"
                               style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                    </VBox>

                    <!-- Progress label -->
                    <Label fx:id="lblProgress" text="83%"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

                    <!-- Continue button -->
                    <Button text="Continue"
                            style="-fx-background-color: #111111; -fx-text-fill: white;
                                   -fx-background-radius: 8; -fx-font-size: 12px;
                                   -fx-padding: 7 16; -fx-cursor: hand;"/>

                    <!-- Navigation arrows -->
                    <Button text="←"
                            style="-fx-background-color: white; -fx-border-color: #ddd;
                                   -fx-border-radius: 50%; -fx-background-radius: 50%;
                                   -fx-min-width: 28; -fx-min-height: 28; -fx-cursor: hand;"/>
                    <Button text="→"
                            style="-fx-background-color: white; -fx-border-color: #ddd;
                                   -fx-border-radius: 50%; -fx-background-radius: 50%;
                                   -fx-min-width: 28; -fx-min-height: 28; -fx-cursor: hand;"/>
                </HBox>

                <!-- Courses Section -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <Label text="Courses"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <!-- Filter Tabs -->
                    <HBox spacing="16">
                        <Button text="All Courses"
                                style="-fx-background-color: transparent; -fx-text-fill: #111; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 4 0; -fx-border-color: transparent transparent #111 transparent; -fx-border-width: 0 0 2 0;"/>
                        <Button text="The Newest"
                                style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-cursor: hand; -fx-padding: 4 0;"/>
                        <Button text="Top Rated"
                                style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-cursor: hand; -fx-padding: 4 0;"/>
                        <Button text="Most Popular"
                                style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-cursor: hand; -fx-padding: 4 0;"/>
                    </HBox>

                    <!-- Course List -->
                    <VBox fx:id="courseList" spacing="8" VBox.vgrow="ALWAYS">

                        <!-- Course Item 1 -->
                        <HBox style="-fx-background-color: white; -fx-background-radius: 12;" prefHeight="52"
                              alignment="CENTER_LEFT" spacing="12">
                            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
                            <Label text="🎨" style="-fx-font-size: 20px;"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Learn Figma" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                                <Label text="by Christopher Morgan" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            </VBox>
                            <Label text="⏱ 6h 30min" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Label text="⭐ 4.9" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Button text="View course"
                                    style="-fx-background-color: #111111; -fx-text-fill: white;
                                           -fx-background-radius: 8; -fx-font-size: 11px;
                                           -fx-padding: 6 12; -fx-cursor: hand;"/>
                        </HBox>

                        <!-- Course Item 2 -->
                        <HBox style="-fx-background-color: white; -fx-background-radius: 12;" prefHeight="52"
                              alignment="CENTER_LEFT" spacing="12">
                            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
                            <Label text="📷" style="-fx-font-size: 20px;"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Analog photography" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                                <Label text="by Gordon Norman" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            </VBox>
                            <Label text="⏱ 3h 15min" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Label text="⭐ 4.7" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Button text="View course"
                                    style="-fx-background-color: #111111; -fx-text-fill: white;
                                           -fx-background-radius: 8; -fx-font-size: 11px;
                                           -fx-padding: 6 12; -fx-cursor: hand;"/>
                        </HBox>

                        <!-- Course Item 3 -->
                        <HBox style="-fx-background-color: white; -fx-background-radius: 12;" prefHeight="52"
                              alignment="CENTER_LEFT" spacing="12">
                            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
                            <Label text="📸" style="-fx-font-size: 20px;"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Master Instagram" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                                <Label text="by Sophie Gill" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            </VBox>
                            <Label text="⏱ 7h 40min" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Label text="⭐ 4.6" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Button text="View course"
                                    style="-fx-background-color: #111111; -fx-text-fill: white;
                                           -fx-background-radius: 8; -fx-font-size: 11px;
                                           -fx-padding: 6 12; -fx-cursor: hand;"/>
                        </HBox>

                        <!-- Course Item 4 -->
                        <HBox style="-fx-background-color: white; -fx-background-radius: 12;" prefHeight="52"
                              alignment="CENTER_LEFT" spacing="12">
                            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
                            <Label text="✏️" style="-fx-font-size: 20px;"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Basics of drawing" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                                <Label text="by Jean Tate" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            </VBox>
                            <Label text="⏱ 11h 30min" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Label text="⭐ 4.8" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Button text="View course"
                                    style="-fx-background-color: #111111; -fx-text-fill: white;
                                           -fx-background-radius: 8; -fx-font-size: 11px;
                                           -fx-padding: 6 12; -fx-cursor: hand;"/>
                        </HBox>

                        <!-- Course Item 5 -->
                        <HBox style="-fx-background-color: white; -fx-background-radius: 12;" prefHeight="52"
                              alignment="CENTER_LEFT" spacing="12">
                            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
                            <Label text="🖼️" style="-fx-font-size: 20px;"/>
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Photoshop - Essence" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                                <Label text="by David Green" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                            </VBox>
                            <Label text="⏱ 5h 35min" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Label text="⭐ 4.7" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                            <Button text="View course"
                                    style="-fx-background-color: #111111; -fx-text-fill: white;
                                           -fx-background-radius: 8; -fx-font-size: 11px;
                                           -fx-padding: 6 12; -fx-cursor: hand;"/>
                        </HBox>

                    </VBox>
                </VBox>
            </VBox>

            <!-- RIGHT PANEL: Statistics + Premium -->
            <VBox spacing="14" prefWidth="300">

                <!-- Statistics Chart Card -->
                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #eeeeee; -fx-border-radius: 16;"
                      VBox.vgrow="ALWAYS">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                    <Label text="Your statistics"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

                    <!-- Tab switcher -->
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="Learning Hours"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #111;"/>
                        <Label text="My Courses"
                               style="-fx-font-size: 12px; -fx-text-fill: #aaa;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="weeklyFilter" value="Weekly" prefWidth="85"
                                  style="-fx-background-radius: 8; -fx-font-size: 11px;"/>
                    </HBox>

                    <!-- Line Chart -->
                    <LineChart fx:id="learningChart" VBox.vgrow="ALWAYS"
                               prefHeight="180"
                               style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <xAxis>
                            <CategoryAxis fx:id="xAxis">
                                <categories>
                                    <String fx:value="mon"/>
                                    <String fx:value="tue"/>
                                    <String fx:value="wed"/>
                                    <String fx:value="thu"/>
                                    <String fx:value="fri"/>
                                    <String fx:value="sat"/>
                                    <String fx:value="sun"/>
                                </categories>
                            </CategoryAxis>
                        </xAxis>
                        <yAxis>
                            <NumberAxis lowerBound="0" upperBound="5" tickUnit="1" fx:id="yAxis"/>
                        </yAxis>
                    </LineChart>
                </VBox>

                <!-- Premium Upsell Card -->
                <HBox prefHeight="100"
                      style="-fx-background-color: #f0f0f0; -fx-background-radius: 16;"
                      spacing="12" alignment="CENTER_LEFT">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Lern even more!"
                               style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Unlock premium features only for $9.99 per month."
                               style="-fx-font-size: 11px; -fx-text-fill: #555; -fx-wrap-text: true;"
                               prefWidth="160"/>
                        <Button fx:id="btnGoPremium" text="Go Premium"
                                style="-fx-background-color: #111111; -fx-text-fill: white;
                                       -fx-background-radius: 8; -fx-font-size: 11px;
                                       -fx-padding: 7 14; -fx-cursor: hand;"/>
                    </VBox>

                    <!-- Brain illustration -->
                    <Label text="🧠" style="-fx-font-size: 48px;"/>
                </HBox>

            </VBox>
        </HBox>
    </VBox>
</HBox>
