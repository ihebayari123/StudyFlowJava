<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.connexion3a36.Controller.HappinessChatbotController"
      prefWidth="900" prefHeight="650">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  PANNEAU GAUCHE — Infos éducatives                        -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <VBox prefWidth="280" minWidth="260" spacing="0"
          style="-fx-background-color: linear-gradient(to bottom, #1a237e, #283593, #3949ab);">
        <padding><Insets top="30" right="20" bottom="30" left="20"/></padding>

        <!-- Logo / Titre -->
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 24 0;">
            <Label text="🎓"
                   style="-fx-font-size: 48px;"/>
            <Label text="EduWell AI"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Georgia';"/>
            <Label text="Analyse de Bien-Être Étudiant"
                   style="-fx-font-size: 11px; -fx-text-fill: #9fa8da; -fx-text-alignment: center;"
                   wrapText="true"/>
        </VBox>

        <!-- Séparateur -->
        <HBox style="-fx-background-color: #5c6bc0; -fx-min-height: 1; -fx-max-height: 1;"/>

        <!-- Infos sur le modèle -->
        <VBox spacing="16" style="-fx-padding: 24 0 0 0;" VBox.vgrow="ALWAYS">
            <Label text="📊 À propos du modèle"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #c5cae9;"/>

            <VBox spacing="10">
                <!-- Carte info 1 -->
                <VBox spacing="4"
                      style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 12;">
                    <Label text="🤖 Algorithme"
                           style="-fx-font-size: 11px; -fx-text-fill: #9fa8da;"/>
                    <Label text="Random Forest Regressor"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </VBox>

                <!-- Carte info 2 -->
                <VBox spacing="4"
                      style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 12;">
                    <Label text="🎯 Objectif"
                           style="-fx-font-size: 11px; -fx-text-fill: #9fa8da;"/>
                    <Label text="Prédire votre score de bonheur (0-100)"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"
                           wrapText="true"/>
                </VBox>

                <!-- Carte info 3 -->
                <VBox spacing="4"
                      style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 12;">
                    <Label text="📋 Variables analysées"
                           style="-fx-font-size: 11px; -fx-text-fill: #9fa8da;"/>
                    <VBox spacing="3">
                        <Label text="• Heures de sommeil"
                               style="-fx-font-size: 11px; -fx-text-fill: #e8eaf6;"/>
                        <Label text="• Heures d'étude"
                               style="-fx-font-size: 11px; -fx-text-fill: #e8eaf6;"/>
                        <Label text="• Âge"
                               style="-fx-font-size: 11px; -fx-text-fill: #e8eaf6;"/>
                        <Label text="• Cafés par jour"
                               style="-fx-font-size: 11px; -fx-text-fill: #e8eaf6;"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- Conseils -->
            <VBox spacing="8" style="-fx-padding: 10 0 0 0;">
                <Label text="💡 Le saviez-vous ?"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #c5cae9;"/>
                <Label text="7-9h de sommeil, 4-6h d'étude et max 2 cafés/jour sont les paramètres optimaux pour le bien-être étudiant."
                       style="-fx-font-size: 11px; -fx-text-fill: #9fa8da; -fx-wrap-text: true;"/>
            </VBox>
        </VBox>

        <!-- Bouton retour -->
        <Button text="← Retour"
                onAction="#goBack"
                maxWidth="Infinity"
                style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                       -fx-background-radius: 10; -fx-font-size: 13px; -fx-padding: 10 0;
                       -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3);
                       -fx-border-radius: 10;"/>
    </VBox>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  PANNEAU DROIT — Chat                                     -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <VBox HBox.hgrow="ALWAYS" spacing="0"
          style="-fx-background-color: #f8f9ff;">

        <!-- Header chat -->
        <HBox prefHeight="70" alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: white;
                     -fx-border-color: transparent transparent #e8eaf6 transparent;
                     -fx-border-width: 0 0 1 0;">
            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>

            <VBox alignment="CENTER"
                  style="-fx-background-color: #3949ab; -fx-background-radius: 50%;
                         -fx-min-width: 44; -fx-min-height: 44; -fx-max-width: 44; -fx-max-height: 44;">
                <Label text="🤖"
                       style="-fx-font-size: 22px;"
                       VBox.vgrow="ALWAYS"
                       alignment="CENTER"/>
            </VBox>

            <VBox spacing="2">
                <Label text="Assistant EduWell"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Circle radius="5" style="-fx-fill: #4caf50;"/>
                    <Label text="En ligne — Analyse IA activée"
                           style="-fx-font-size: 11px; -fx-text-fill: #4caf50;"/>
                </HBox>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="progressLabel"
                   text="0 / 4 questions"
                   style="-fx-font-size: 12px; -fx-text-fill: #7986cb;
                          -fx-background-color: #e8eaf6; -fx-padding: 5 12; -fx-background-radius: 20;"/>
        </HBox>

        <!-- Zone de messages -->
        <ScrollPane fx:id="chatScrollPane" VBox.vgrow="ALWAYS"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: #f8f9ff; -fx-border-color: transparent;">
            <VBox fx:id="chatMessagesBox" spacing="12">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            </VBox>
        </ScrollPane>

        <!-- Zone résultat (cachée par défaut) -->
        <VBox fx:id="resultBox" visible="false" managed="false" spacing="0"
              style="-fx-background-color: white;
                     -fx-border-color: #e8eaf6 transparent transparent transparent;
                     -fx-border-width: 1 0 0 0;">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <HBox spacing="20" alignment="CENTER">
                <!-- Score -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: linear-gradient(to bottom, #1a237e, #3949ab);
                             -fx-background-radius: 16; -fx-padding: 20 30;">
                    <Label text="🎯 Score de Bonheur"
                           style="-fx-font-size: 12px; -fx-text-fill: #c5cae9;"/>
                    <Label fx:id="resultScoreLabel"
                           text="--"
                           style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="/ 100"
                           style="-fx-font-size: 14px; -fx-text-fill: #9fa8da;"/>
                </VBox>

                <!-- Interprétation -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label fx:id="resultEmojiLabel"
                           text="😊"
                           style="-fx-font-size: 36px;"/>
                    <Label fx:id="resultTitleLabel"
                           text=""
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a237e;"
                           wrapText="true"/>
                    <Label fx:id="resultDescLabel"
                           text=""
                           style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-wrap-text: true;"
                           maxWidth="320"/>
                </VBox>
            </HBox>

            <!-- Recommandations -->
            <VBox fx:id="recommendationsBox" spacing="6" style="-fx-padding: 16 0 0 0;">
                <Label text="📌 Recommandations personnalisées :"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3949ab;"/>
                <Label fx:id="rec1Label" text="" wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                <Label fx:id="rec2Label" text="" wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
                <Label fx:id="rec3Label" text="" wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #444;"/>
            </VBox>
        </VBox>

        <!-- Zone de saisie -->
        <HBox prefHeight="64" alignment="CENTER" spacing="12"
              style="-fx-background-color: white;
                     -fx-border-color: #e8eaf6 transparent transparent transparent;
                     -fx-border-width: 1 0 0 0;">
            <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>

            <Button fx:id="btnReset"
                    text="🔄"
                    onAction="#resetChat"
                    style="-fx-background-color: #e8eaf6; -fx-text-fill: #3949ab;
                           -fx-background-radius: 50%; -fx-min-width: 40; -fx-min-height: 40;
                           -fx-max-width: 40; -fx-max-height: 40; -fx-cursor: hand;
                           -fx-font-size: 16px;"/>

            <TextField fx:id="answerField"
                       HBox.hgrow="ALWAYS"
                       prefHeight="44"
                       promptText="Tapez votre réponse..."
                       style="-fx-background-color: #f0f2ff; -fx-border-color: #c5cae9;
                              -fx-border-radius: 22; -fx-background-radius: 22;
                              -fx-padding: 0 16; -fx-font-size: 14px;"/>

            <Button fx:id="btnSend"
                    text="Envoyer ➤"
                    onAction="#submitAnswer"
                    disable="true"
                    style="-fx-background-color: #3949ab; -fx-text-fill: white;
                           -fx-background-radius: 22; -fx-font-size: 13px;
                           -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</HBox>
