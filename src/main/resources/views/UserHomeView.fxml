<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.connexion3a36.Controller.UserHomeController"
      spacing="0"
      style="-fx-background-color:#F2F2F2; -fx-font-family:'Courier New';">

    <!-- TOPBAR interne -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color:#FFFFFF; -fx-min-height:46;
                 -fx-border-color:#1A1A1A; -fx-border-width:0 0 3 0;">
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#C47A00; -fx-padding:0 16;
                     -fx-min-height:46; -fx-border-color:#1A1A1A; -fx-border-width:0 3 0 0;">
            <Label text="QUIZ — STUDYFLOW"
                   style="-fx-font-family:'Courier New'; -fx-font-size:12;
                          -fx-font-weight:bold; -fx-text-fill:#FFFFFF; -fx-letter-spacing:1;"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-background-color:#F5F5F5; -fx-border-color:#DDDDDD;
                     -fx-border-width:0 1 0 1; -fx-padding:0 12;
                     -fx-min-height:46; -fx-max-width:260;"
              HBox.hgrow="ALWAYS">
            <Label text="/" style="-fx-font-family:'Courier New'; -fx-font-size:13; -fx-text-fill:#AAAAAA;"/>
            <TextField fx:id="tfRecherche" promptText="RECHERCHER..."
                       style="-fx-background-color:transparent; -fx-border-color:transparent;
                              -fx-font-family:'Courier New'; -fx-font-size:11;
                              -fx-text-fill:#1A1A1A; -fx-prompt-text-fill:#AAAAAA;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="cbDifficulte" prefWidth="200"
                  style="-fx-background-color:#F5F5F5; -fx-border-color:#1A1A1A;
                         -fx-border-width:0 0 0 2; -fx-background-radius:0;
                         -fx-font-family:'Courier New'; -fx-font-size:10; -fx-min-height:46;"/>
        <!-- Stats chips -->
        <HBox alignment="CENTER" spacing="0"
              style="-fx-background-color:#0A5A8A; -fx-padding:0 14; -fx-min-height:46;
                     -fx-border-color:#1A1A1A; -fx-border-width:0 0 0 3;">
            <Label fx:id="lblTotalQuiz" text="--"
                   style="-fx-font-family:'Courier New'; -fx-font-size:16; -fx-font-weight:bold;
                          -fx-text-fill:#FFFFFF;"/>
            <Label text=" QUIZ"
                   style="-fx-font-family:'Courier New'; -fx-font-size:9; -fx-font-weight:bold;
                          -fx-text-fill:rgba(255,255,255,0.7); -fx-letter-spacing:1;"/>
        </HBox>
    </HBox>

    <!-- BODY -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:#F2F2F2; -fx-background-color:#F2F2F2; -fx-border-color:transparent;">
        <VBox spacing="0" style="-fx-padding:18; -fx-background-color:#F2F2F2;">

            <!-- HERO BANNER avec offset shadow -->
            <StackPane style="-fx-padding:0 0 16 0;">
                <VBox style="-fx-background-color:#C47A00;
                             -fx-translate-x:7; -fx-translate-y:7; -fx-min-height:140;"/>
                <VBox style="-fx-background-color:#0A5A8A;
                             -fx-border-color:#1A1A1A; -fx-border-width:4; -fx-padding:22 26;">
                    <Label text="MODULE QUIZ &amp; QUESTIONS"
                           style="-fx-font-family:'Courier New'; -fx-font-size:9; -fx-font-weight:bold;
                                  -fx-letter-spacing:3; -fx-text-fill:rgba(255,255,255,0.6); -fx-padding:0 0 6 0;"/>
                    <Label text="TESTEZ VOS CONNAISSANCES"
                           style="-fx-font-family:'Courier New'; -fx-font-size:20; -fx-font-weight:bold;
                                  -fx-text-fill:#FFFFFF;"/>
                    <Label text="Choisissez un quiz. Repondez question par question. Voyez votre score."
                           style="-fx-font-family:'Courier New'; -fx-font-size:11;
                                  -fx-text-fill:rgba(255,255,255,0.7); -fx-padding:6 0 14 0; -fx-max-width:400;"/>
                    <HBox spacing="0">
                        <VBox alignment="CENTER"
                              style="-fx-background-color:rgba(255,255,255,0.12);
                                     -fx-border-color:rgba(255,255,255,0.4);
                                     -fx-border-width:2; -fx-padding:8 16; -fx-min-width:80;">
                            <Label fx:id="lblTotalQuiz" text="--"
                                   style="-fx-font-family:'Courier New'; -fx-font-size:22;
                                          -fx-font-weight:bold; -fx-text-fill:#FFF0CC;"/>
                            <Label text="QUIZ"
                                   style="-fx-font-family:'Courier New'; -fx-font-size:8;
                                          -fx-font-weight:bold; -fx-text-fill:rgba(255,255,255,0.7); -fx-letter-spacing:2;"/>
                        </VBox>
                        <VBox alignment="CENTER"
                              style="-fx-background-color:rgba(255,255,255,0.12);
                                     -fx-border-color:rgba(255,255,255,0.4);
                                     -fx-border-width:2 2 2 0; -fx-padding:8 16; -fx-min-width:80;">
                            <Label fx:id="lblCompletes" text="0"
                                   style="-fx-font-family:'Courier New'; -fx-font-size:22;
                                          -fx-font-weight:bold; -fx-text-fill:#FFF0CC;"/>
                            <Label text="COMPLETES"
                                   style="-fx-font-family:'Courier New'; -fx-font-size:8;
                                          -fx-font-weight:bold; -fx-text-fill:rgba(255,255,255,0.7); -fx-letter-spacing:2;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </StackPane>

            <!-- SECTION LABEL -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-border-color:#1A1A1A; -fx-border-width:0 0 3 0; -fx-padding:12 0 8 0;">
                <Label text="// QUIZ DISPONIBLES"
                       style="-fx-font-family:'Courier New'; -fx-font-size:10; -fx-font-weight:bold;
                              -fx-letter-spacing:2; -fx-text-fill:#888888;"/>
            </HBox>

            <!-- GRILLE quiz — cartes générées dynamiquement -->
            <FlowPane fx:id="quizGrid" hgap="16" vgap="16"
                      prefWrapLength="860"
                      style="-fx-background-color:transparent; -fx-padding:14 0 0 0;"/>

        </VBox>
    </ScrollPane>
</VBox>
