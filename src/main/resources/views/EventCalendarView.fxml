<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.connexion3a36.Controller.EventCalendarController"
      spacing="0" prefWidth="1000" prefHeight="700"
      style="-fx-background-color: #0a0a0f;">

    <!-- HEADER -->
    <HBox prefHeight="64" alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: #111111; -fx-padding: 0 24;">
        <Button text="← Retour" onAction="#goBack"
                style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white;
                       -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 10;
                       -fx-background-radius: 10; -fx-padding: 7 14; -fx-cursor: hand; -fx-font-size: 13px;"/>
        <Label text="📅 Calendrier des Événements"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Georgia';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnPrevMonth" text="‹" onAction="#prevMonth"
                style="-fx-font-size: 18px; -fx-background-color: rgba(255,255,255,0.1);
                       -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-min-width: 34;"/>
        <Label fx:id="lblMonthYear" text="Avril 2026"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white; -fx-min-width: 140; -fx-alignment: CENTER;"/>
        <Button fx:id="btnNextMonth" text="›" onAction="#nextMonth"
                style="-fx-font-size: 18px; -fx-background-color: rgba(255,255,255,0.1);
                       -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-min-width: 34;"/>
        <Button fx:id="btnToday" text="Aujourd'hui" onAction="#goToday"
                style="-fx-background-color: #7c6fff; -fx-text-fill: white;
                       -fx-background-radius: 8; -fx-padding: 7 14; -fx-cursor: hand; -fx-font-size: 12px;"/>
        <Label fx:id="lblEventCount" text="0 événement(s)"
               style="-fx-font-size: 12px; -fx-text-fill: #4CAF50;
                      -fx-background-color: rgba(76,175,80,0.2); -fx-padding: 5 12; -fx-background-radius: 20;"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- CALENDAR GRID -->
        <VBox HBox.hgrow="ALWAYS" spacing="0"
              style="-fx-background-color: #0d0d18; -fx-padding: 16;">

            <!-- Day headers -->
            <HBox fx:id="headerRow" spacing="3" style="-fx-padding: 0 0 6 0;"/>

            <!-- Grid rows -->
            <VBox fx:id="calendarGrid" VBox.vgrow="ALWAYS" spacing="3"/>
        </VBox>

        <!-- RIGHT SIDEBAR -->
        <VBox prefWidth="240" spacing="16"
              style="-fx-background-color: #111118; -fx-padding: 20 16;
                     -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 0 1;">

            <Label text="Prochains événements"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.5);"/>
            <ScrollPane fx:id="upcomingScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"/>
            <Label text="Légende"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.4);"/>
            <VBox fx:id="legendBox" spacing="6"/>
        </VBox>
    </HBox>
</VBox>