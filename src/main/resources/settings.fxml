<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.Controller.SettingsController">

    <VBox spacing="8">
        <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="⚙️ Paramètres" />
        <Label style="-fx-font-size: 14; -fx-text-fill: #757575;" text="Personnalisez votre application" />
    </VBox>

    <VBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 20;">
        <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Notifications" />
        <HBox spacing="10">
            <Label text="Activer les rappels de quiz" HBox.hgrow="ALWAYS" />
            <Button text="Activé" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 12;" />
        </HBox>
        <HBox spacing="10">
            <Label text="Mode sombre" HBox.hgrow="ALWAYS" />
            <Button text="Désactivé" style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 12;" />
        </HBox>
    </VBox>

</VBox>