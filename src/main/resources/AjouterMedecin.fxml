<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<AnchorPane
        prefHeight="620.0" prefWidth="580.0"
        style="-fx-background-color: #eef2eb;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="edu.connexion3a36.Controller.AjouterMedecinController">

    <children>

        <Rectangle width="8" height="620" layoutX="0" layoutY="0" fill="#2d6a4f"/>
        <Rectangle width="580" height="4" layoutX="0" layoutY="0" fill="#c8a84b"/>

        <VBox layoutX="8" layoutY="4" prefWidth="572" spacing="0">

            <!-- HEADER -->
            <HBox style="-fx-background-color: #ffffff;" alignment="CENTER_LEFT" spacing="0" prefHeight="100">
                <VBox style="-fx-background-color: #2d6a4f;" prefWidth="180" prefHeight="100"
                      alignment="CENTER" spacing="2">
                    <Label text="STUDYFLOW"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #c8a84b; -fx-font-family: 'Palatino Linotype';"/>
                    <Label text="🩺" style="-fx-font-size: 28px;"/>
                    <Label text="GESTION MÉDICALE"
                           style="-fx-font-size: 8px; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-family: 'Palatino Linotype';"/>
                </VBox>
                <VBox prefWidth="392" prefHeight="100" alignment="CENTER_LEFT" spacing="4">
                    <padding><Insets left="24" right="20"/></padding>
                    <Label text="Ajouter un Médecin"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a3320; -fx-font-family: 'Palatino Linotype';"/>
                    <Label text="Formulaire d'enregistrement — Service Médical"
                           style="-fx-font-size: 11px; -fx-text-fill: #6b8f71; -fx-font-family: 'Palatino Linotype';"/>
                    <Rectangle width="160" height="2" fill="#c8a84b"/>
                </VBox>
            </HBox>

            <HBox style="-fx-background-color: #d4e6d4;" prefHeight="1"/>

            <!-- BODY -->
            <HBox style="-fx-background-color: #ffffff;" spacing="0" prefHeight="460">

                <!-- Colonne gauche -->
                <VBox prefWidth="168"
                      style="-fx-background-color: #f5f9f5; -fx-border-color: #d4e6d4; -fx-border-width: 0 1 0 0;"
                      spacing="0">
                    <padding><Insets top="28" bottom="20" left="16" right="16"/></padding>

                    <Label text="INFORMATIONS"
                           style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #c8a84b; -fx-font-family: 'Palatino Linotype';"/>

                    <Rectangle width="136" height="1" fill="#d4e6d4">
                        <VBox.margin><Insets top="8" bottom="16"/></VBox.margin>
                    </Rectangle>

                    <VBox spacing="3" style="-fx-background-color: #eef7ee; -fx-background-radius: 8; -fx-padding: 12;">
                        <Label text="👤  Identité"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <Label text="Nom et prénom\ndu médecin"
                               style="-fx-font-size: 10px; -fx-text-fill: #6b8f71; -fx-font-family: 'Palatino Linotype';"/>
                        <VBox.margin><Insets bottom="10"/></VBox.margin>
                    </VBox>

                    <VBox spacing="3" style="-fx-background-color: #fdf8ec; -fx-background-radius: 8; -fx-padding: 12;">
                        <Label text="📧  Contact"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <Label text="Email et\ntéléphone"
                               style="-fx-font-size: 10px; -fx-text-fill: #6b8f71; -fx-font-family: 'Palatino Linotype';"/>
                        <VBox.margin><Insets bottom="10"/></VBox.margin>
                    </VBox>

                    <VBox spacing="3" style="-fx-background-color: #eef7ee; -fx-background-radius: 8; -fx-padding: 12;">
                        <Label text="📅  Disponibilité"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <Label text="Statut de\ndisponibilité"
                               style="-fx-font-size: 10px; -fx-text-fill: #6b8f71; -fx-font-family: 'Palatino Linotype';"/>
                        <VBox.margin><Insets bottom="10"/></VBox.margin>
                    </VBox>

                    <VBox alignment="CENTER" spacing="2"
                          style="-fx-background-color: #2d6a4f; -fx-background-radius: 10; -fx-padding: 14;">
                        <VBox.margin><Insets top="14"/></VBox.margin>
                        <Label text="MÉDECIN"
                               style="-fx-font-size: 9px; -fx-text-fill: #c8a84b; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype';"/>
                        <Label text="🩺" style="-fx-font-size: 22px;"/>
                        <Label text="Service de santé"
                               style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-family: 'Palatino Linotype';"/>
                    </VBox>
                </VBox>

                <!-- Colonne droite formulaire -->
                <VBox prefWidth="404" spacing="18">
                    <padding><Insets top="30" bottom="24" left="30" right="30"/></padding>

                    <Label text="SAISIR LES DONNÉES"
                           style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #c8a84b; -fx-font-family: 'Palatino Linotype';"/>

                    <VBox spacing="5">
                        <Label text="Nom"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <TextField fx:id="nomTF" promptText="Ex : Ben Ali" prefHeight="38"
                                   style="-fx-background-color: #f5f9f5; -fx-border-color: #b5d5b5;
                                    -fx-border-width: 0 0 2 0; -fx-background-radius: 4 4 0 0;
                                    -fx-text-fill: #1a3320; -fx-prompt-text-fill: #a0bea0;
                                    -fx-font-family: 'Palatino Linotype'; -fx-font-size: 12px; -fx-padding: 8 12;"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Prénom"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <TextField fx:id="prenomTF" promptText="Ex : Mohamed" prefHeight="38"
                                   style="-fx-background-color: #f5f9f5; -fx-border-color: #b5d5b5;
                                    -fx-border-width: 0 0 2 0; -fx-background-radius: 4 4 0 0;
                                    -fx-text-fill: #1a3320; -fx-prompt-text-fill: #a0bea0;
                                    -fx-font-family: 'Palatino Linotype'; -fx-font-size: 12px; -fx-padding: 8 12;"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Email"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <TextField fx:id="emailTF" promptText="Ex : medecin@hopital.tn" prefHeight="38"
                                   style="-fx-background-color: #f5f9f5; -fx-border-color: #b5d5b5;
                                    -fx-border-width: 0 0 2 0; -fx-background-radius: 4 4 0 0;
                                    -fx-text-fill: #1a3320; -fx-prompt-text-fill: #a0bea0;
                                    -fx-font-family: 'Palatino Linotype'; -fx-font-size: 12px; -fx-padding: 8 12;"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Téléphone"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label fx:id="drapeauLabel" style="-fx-font-size: 24px;" prefWidth="40" alignment="CENTER"/>
                            <TextField fx:id="telephoneTF" promptText="Ex : +212612345678" prefHeight="38" prefWidth="296"
                                       style="-fx-background-color: #f5f9f5; -fx-border-color: #b5d5b5;
                                        -fx-border-width: 0 0 2 0; -fx-background-radius: 4 4 0 0;
                                        -fx-text-fill: #1a3320; -fx-prompt-text-fill: #a0bea0;
                                        -fx-font-family: 'Palatino Linotype'; -fx-font-size: 12px; -fx-padding: 8 12;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Disponibilité"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                        <ComboBox fx:id="disponibiliteCB" prefHeight="38" prefWidth="344"
                                  style="-fx-background-color: #fdf8ec; -fx-border-color: #c8a84b;
                                   -fx-border-width: 0 0 2 0; -fx-background-radius: 4 4 0 0;
                                   -fx-font-family: 'Palatino Linotype'; -fx-font-size: 12px;"/>
                    </VBox>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <VBox.margin><Insets top="6"/></VBox.margin>
                        <Button text="✦  Enregistrer le Médecin" onAction="#ajouter"
                                prefHeight="44" prefWidth="240"
                                style="-fx-background-color: #2d6a4f; -fx-text-fill: white;
                                 -fx-font-size: 12px; -fx-font-weight: bold;
                                 -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 4;
                                 -fx-cursor: hand;
                                 -fx-effect: dropshadow(gaussian, rgba(45,106,79,0.4), 10, 0, 0, 3);"/>
                        <Button text="📋  Consulter la Liste" onAction="#consulterListe"
                                prefHeight="44" prefWidth="150"
                                style="-fx-background-color: #2d6a4f; -fx-text-fill: white;
                                 -fx-font-size: 12px; -fx-font-weight: bold;
                                 -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 4;
                                 -fx-cursor: hand;
                                 -fx-effect: dropshadow(gaussian, rgba(45,106,79,0.4), 10, 0, 0, 3);"/>
                        <Button text="↺  Réinitialiser" onAction="#reinitialiser"
                                prefHeight="44" prefWidth="100"
                                style="-fx-background-color: transparent; -fx-text-fill: #6b8f71;
                                 -fx-font-size: 11px; -fx-font-family: 'Palatino Linotype';
                                 -fx-border-color: #b5d5b5; -fx-border-width: 1.5;
                                 -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
                    </HBox>

                </VBox>
            </HBox>

            <!-- FOOTER -->
            <HBox prefHeight="56" style="-fx-background-color: #2d6a4f;" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets left="24" right="24"/></padding>
                <Rectangle width="2" height="28" fill="#c8a84b"/>
                <VBox spacing="2">
                    <Label text="Université — Service de Santé Étudiante"
                           style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-family: 'Palatino Linotype';"/>
                    <Label text="Toutes les données sont confidentielles et sécurisées"
                           style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.5); -fx-font-family: 'Palatino Linotype';"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="🔒 Confidentiel"
                       style="-fx-font-size: 10px; -fx-text-fill: #c8a84b; -fx-font-family: 'Palatino Linotype';"/>
            </HBox>

        </VBox>
    </children>
</AnchorPane>
