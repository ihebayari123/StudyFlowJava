<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="0"
      style="-fx-background-color: #F5F6FA; -fx-padding: 32 32 32 32;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.AnomalyDashboardController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding: 0 0 24 0;">
        <Label text="🛡️" style="-fx-font-size: 28;" />
        <VBox spacing="2">
            <Label text="Détection d'Anomalies"
                   style="-fx-font-size: 22; -fx-font-weight: bold;
                          -fx-text-fill: #1A1A2E;" />
            <Label text="Analyse comportementale des comptes utilisateurs"
                   style="-fx-font-size: 12; -fx-text-fill: #9E9E9E;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAnalyser" text="🔄 Analyser"
                style="-fx-background-color: #2979FF;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 10 20 10 20;
                       -fx-cursor: hand;"
                onAction="#lancerAnalyse" />
        <Button fx:id="btnBloquerAuto" text="🔒 Bloquer les HIGH"
                style="-fx-background-color: #E53935;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 10 20 10 20;
                       -fx-cursor: hand;"
                onAction="#bloquerComptesHigh" />
    </HBox>

    <!-- STATS CARDS -->
    <HBox spacing="16" style="-fx-padding: 0 0 24 0;">

        <VBox fx:id="cardHigh" alignment="CENTER" prefWidth="160" prefHeight="80"
              style="-fx-background-color: #FFEBEE;
                     -fx-background-radius: 12;
                     -fx-padding: 16;">
            <Label text="🔴 HIGH" style="-fx-font-size: 13; -fx-text-fill: #E53935;" />
            <Label fx:id="countHigh" text="0"
                   style="-fx-font-size: 28; -fx-font-weight: bold;
                          -fx-text-fill: #E53935;" />
        </VBox>

        <VBox fx:id="cardMedium" alignment="CENTER" prefWidth="160" prefHeight="80"
              style="-fx-background-color: #FFF8E1;
                     -fx-background-radius: 12;
                     -fx-padding: 16;">
            <Label text="🟡 MEDIUM" style="-fx-font-size: 13; -fx-text-fill: #F57F17;" />
            <Label fx:id="countMedium" text="0"
                   style="-fx-font-size: 28; -fx-font-weight: bold;
                          -fx-text-fill: #F57F17;" />
        </VBox>

        <VBox fx:id="cardLow" alignment="CENTER" prefWidth="160" prefHeight="80"
              style="-fx-background-color: #E8F5E9;
                     -fx-background-radius: 12;
                     -fx-padding: 16;">
            <Label text="🟢 LOW" style="-fx-font-size: 13; -fx-text-fill: #2E7D32;" />
            <Label fx:id="countLow" text="0"
                   style="-fx-font-size: 28; -fx-font-weight: bold;
                          -fx-text-fill: #2E7D32;" />
        </VBox>

        <VBox fx:id="cardTotal" alignment="CENTER" prefWidth="160" prefHeight="80"
              style="-fx-background-color: #E3F2FD;
                     -fx-background-radius: 12;
                     -fx-padding: 16;">
            <Label text="📊 TOTAL" style="-fx-font-size: 13; -fx-text-fill: #1565C0;" />
            <Label fx:id="countTotal" text="0"
                   style="-fx-font-size: 28; -fx-font-weight: bold;
                          -fx-text-fill: #1565C0;" />
        </VBox>

    </HBox>

    <!-- STATUS LABEL -->
    <Label fx:id="statusLabel" text="Cliquez sur Analyser pour lancer la détection..."
           style="-fx-font-size: 12; -fx-text-fill: #9E9E9E;
                  -fx-padding: 0 0 12 0;" />

    <!-- TABLE -->
    <TableView fx:id="tableAnomalies" VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-border-color: #E0E0E0;
                      -fx-border-width: 1;">

        <columns>
            <TableColumn fx:id="colNom"     text="Nom"    prefWidth="130" />
            <TableColumn fx:id="colPrenom"  text="Prénom" prefWidth="120" />
            <TableColumn fx:id="colEmail"   text="Email"  prefWidth="200" />
            <TableColumn fx:id="colRole"    text="Rôle"   prefWidth="110" />
            <TableColumn fx:id="colStatut"  text="Statut" prefWidth="90"  />
            <TableColumn fx:id="colScore"   text="Score"  prefWidth="80"  />
            <TableColumn fx:id="colNiveau"  text="Niveau" prefWidth="100" />
            <TableColumn fx:id="colRaisons" text="Raisons détectées" prefWidth="280" />
            <TableColumn fx:id="colAction"  text="Action" prefWidth="100" />
        </columns>

        <placeholder>
            <Label text="Aucune donnée — cliquez sur Analyser"
                   style="-fx-text-fill: #9E9E9E; -fx-font-size: 13;" />
        </placeholder>
    </TableView>

</VBox>