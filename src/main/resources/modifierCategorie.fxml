<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 32; -fx-background-color: #F5F6FA;"
      prefWidth="400"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.ModifierCategorieController">

    <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="✏️ Modifier la Catégorie" />

    <VBox spacing="6">
        <Label style="-fx-font-size: 13; -fx-text-fill: #757575;" text="Nom de la catégorie" />
        <TextField fx:id="nomField"
                   style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 10;" />
    </VBox>

    <VBox spacing="6">
        <Label style="-fx-font-size: 13; -fx-text-fill: #757575;" text="Description" />
        <TextArea fx:id="descField"
                  prefRowCount="3"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 10;" />
    </VBox>

    <HBox spacing="12">
        <Button fx:id="saveBtn" text="💾 Enregistrer" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-background-radius: 8;
                       -fx-padding: 10; -fx-font-weight: bold; -fx-cursor: hand;" />
        <Button fx:id="cancelBtn" text="Annuler" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                style="-fx-background-color: #E0E0E0; -fx-text-fill: #757575; -fx-background-radius: 8;
                       -fx-padding: 10; -fx-cursor: hand;" />
    </HBox>

    <Label fx:id="statusLabel" style="-fx-font-size: 13;" text="" />

</VBox>