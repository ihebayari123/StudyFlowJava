<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<?import javafx.geometry.Insets?>
<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f5f6fa; -fx-cursor: default;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.connexion3a36.Controller.AdminController">
     
    <!-- Modern gradient background with green tones -->
    <Rectangle arcHeight="40.0" arcWidth="40.0" fill="linear-gradient(#2d6a4f 0%, #4a8b6d 100%)" height="700" width="1000" />
    
    <!-- Main white card with subtle shadow -->
    <AnchorPane prefHeight="700" prefWidth="1000" style="-fx-background-color: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 30, 0, 0, 15);">
        
        <!-- Top accent bar -->
        <Rectangle height="8" width="1000" fill="#2d6a4f"/>
        <Rectangle height="4" width="1000" layoutY="8" fill="#c8a84b"/>
        
        <!-- Header with prominent Administration title -->
        <HBox prefHeight="70" prefWidth="1000" style="-fx-background-color: #ffffff;" xmlns:fx="http://javafx.com/fxml/1">
            <VBox prefWidth="400" prefHeight="70" alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="0" bottom="0" left="40" right="20"/></padding>
                <Label text="ADMINISTRATION" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype'; -fx-font-style: italic;"/>
                <Label text="Tableau de bord administratif" style="-fx-font-size: 14px; -fx-text-fill: #6b8f71; -fx-font-family: 'Palatino Linotype';"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="4">
                <padding><Insets top="0" bottom="0" left="0" right="40"/></padding>
                <Label text="Bienvenue, Administrateur" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                <Label text="🔒 Connecté" style="-fx-font-size: 12px; -fx-text-fill: #c8a84b; -fx-font-family: 'Palatino Linotype';"/>
            </VBox>
        </HBox>
        
        <!-- Main content area -->
        <AnchorPane prefHeight="615" prefWidth="1000" layoutY="70">
            
            <!-- Sidebar with modern button layout -->
            <VBox prefWidth="280" prefHeight="615" style="-fx-background-color: #ffffff; -fx-border-radius: 0 0 40 0; -fx-background-radius: 0 0 40 0;">
                <padding><Insets top="30" bottom="30" left="0" right="0"/></padding>
                
                <!-- Buttons with icons and clean styling -->
                <VBox spacing="20" style="-fx-padding: 0 20 0 40;">
                    
                    <!-- Add Doctor -->
                    <Button text="  ➕  Ajouter Médecin" onAction="#ajouterMedecin" prefHeight="55" prefWidth="240"
                            style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45,106,79,0.25), 10, 0, 0, 3);"
                            HBox.hgrow="ALWAYS"/>
                    
                    <!-- View Doctors List -->
                    <Button text="  👥  Liste Médecins" onAction="#voirListeMedecins" prefHeight="55" prefWidth="240"
                            style="-fx-background-color: #f8f9fa; -fx-text-fill: #2d6a4f; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 5, 0, 0, 2);"
                            HBox.hgrow="ALWAYS"/>
                    
                    <!-- Add Consultation -->
                    <Button text="  📅  Ajouter Consultation" onAction="#ajouterConsultation" prefHeight="55" prefWidth="240"
                            style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45,106,79,0.25), 10, 0, 0, 3);"
                            HBox.hgrow="ALWAYS"/>
                    
                    <!-- View Consultations -->
                    <Button text="  📋  Liste Consultations" onAction="#voirConsultations" prefHeight="55" prefWidth="240"
                            style="-fx-background-color: #f8f9fa; -fx-text-fill: #2d6a4f; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 5, 0, 0, 2);"
                            HBox.hgrow="ALWAYS"/>
                    
                    <!-- Anti-Stress -->
                    <Button text="  🧘  Anti-Stresse" onAction="#antiStress" prefHeight="55" prefWidth="240"
                            style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45,106,79,0.25), 10, 0, 0, 3);"
                            HBox.hgrow="ALWAYS"/>
                    
                    <!-- Add Student Stress Score -->
                    <Button text="  ➕  Ajouter score-etudiant" onAction="#ajouterStressSurvey" prefHeight="55" prefWidth="240"
                            style="-fx-background-color: #f8f9fa; -fx-text-fill: #2d6a4f; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 5, 0, 0, 2);"
                            HBox.hgrow="ALWAYS"/>
                    
                    <!-- Add Well Being Student Score -->
                    <Button text="  📝  + etudiant" onAction="#ajouterWellBeingScore" prefHeight="55" prefWidth="240"
                            style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(45,106,79,0.25), 10, 0, 0, 3);"
                            HBox.hgrow="ALWAYS"/>
                    
                    <!-- Spacer -->
                    <Region prefHeight="20" VBox.vgrow="ALWAYS"/>
                    
                    <!-- View Well Being Score -->
                    <Button text="  📊  Voir Score" onAction="#voirWellBeingScore" prefHeight="45" prefWidth="240"
                            style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand;"
                            HBox.hgrow="ALWAYS"/>

                    <!-- Logout -->
                    <Button text="  🚪  Déconnexion" onAction="#deconnexion" prefHeight="45" prefWidth="240"
                            style="-fx-background-color: #e9ecef; -fx-text-fill: #333333; -fx-font-size: 15px; -fx-font-weight: bold; -fx-font-family: 'Palatino Linotype'; -fx-background-radius: 12; -fx-cursor: hand;"
                            HBox.hgrow="ALWAYS"/>
                </VBox>
            </VBox>
            
            <!-- Dynamic content area -->
            <StackPane fx:id="contentArea" prefHeight="615" prefWidth="720" layoutX="280"
                       style="-fx-background-color: #f5f6fa; -fx-cursor: default;">
                <!-- Default content -->
                <VBox alignment="CENTER" spacing="15">
                    <Label text="Bienvenue dans le tableau de bord administratif"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f; -fx-font-family: 'Palatino Linotype';"/>
                    <Label text="Sélectionnez une option dans le menu pour commencer"
                           style="-fx-font-size: 18px; -fx-text-fill: #6b8f71; -fx-font-family: 'Palatino Linotype';"/>
                </VBox>
            </StackPane>
        </AnchorPane>
        
        <!-- Footer -->
        <HBox prefHeight="40" prefWidth="1000" layoutY="660" style="-fx-background-color: #2d6a4f;" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="0" bottom="0" left="40" right="40"/></padding>
            <Rectangle width="3" height="26" fill="#c8a84b"/>
            <VBox spacing="2">
                <Label text="Université — Service de Santé Étudiante"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-family: 'Palatino Linotype';"/>
                <Label text="Toutes les données sont confidentielles et sécurisées"
                       style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.5); -fx-font-family: 'Palatino Linotype';"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="🔒 Confidentiel"
                   style="-fx-font-size: 11px; -fx-text-fill: #c8a84b; -fx-font-family: 'Palatino Linotype';"/>
        </HBox>
    </AnchorPane>
 </AnchorPane>