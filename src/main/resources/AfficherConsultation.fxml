<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.control.Separator?>

<VBox spacing="20" style="-fx-background-color: #F5F6FA; -fx-padding: 25;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.AfficherConsultationController">

    <!-- Header avec icône et titre -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Rectangle height="30" width="5" style="-fx-fill: #2979FF; -fx-arc-width: 3; -fx-arc-height: 3;" />
        <Label text="Liste des Consultations"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
    </HBox>

    <Separator style="-fx-background-color: #E0E0E0;" />

    <!-- Filtre et Tri - Style moderne -->
    <VBox spacing="12">
        <Label text="🔍 Filtres et tri"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Trier par :" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
            <ComboBox fx:id="triCB" prefWidth="130" promptText="Choisir tri"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>
            <ComboBox fx:id="ordreCB" prefWidth="80" promptText="Ordre"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>

            <Label text="Filtrer par date :" style="-fx-text-fill: #757575; -fx-font-size: 13px;"/>
            <DatePicker fx:id="filtreDatePicker" promptText="Sélectionner date"
                        style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>

            <Button fx:id="btnResetFiltre" text="🔄 Réinitialiser" onAction="#resetFiltre"
                    style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 15; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- TableView - Style moderne -->
    <TableView fx:id="tableView" prefHeight="280"
               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E0E0E0; -fx-border-radius: 12; -fx-border-width: 1;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
            <TableColumn fx:id="colMotif" text="Motif" prefWidth="150"/>
            <TableColumn fx:id="colGenre" text="Genre" prefWidth="80"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="80"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colMedecinId" text="Médecin ID" prefWidth="90"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colSurveyId" text="Survey ID" prefWidth="90"
                         style="-fx-alignment: CENTER;"/>
        </columns>
    </TableView>

    <!-- Section modification -->
    <VBox spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Rectangle height="18" width="3" style="-fx-fill: #2979FF; -fx-arc-width: 2; -fx-arc-height: 2;" />
            <Label text="Modifier la consultation sélectionnée"
                   style="-fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-size: 14px; -fx-font-family: 'Segoe UI';"/>
        </HBox>

        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 12;">

            <!-- Ligne 1 -->
            <HBox spacing="20">
                <VBox spacing="5">
                    <Label text="Date" style="-fx-text-fill: #757575; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="datePicker"
                                style="-fx-background-color: #F8F9FA; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Motif" style="-fx-text-fill: #757575; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="motifTF" prefWidth="180"
                               style="-fx-background-color: #F8F9FA; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 8;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Genre" style="-fx-text-fill: #757575; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="genreCB" prefWidth="120"
                              style="-fx-background-color: #F8F9FA; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Niveau" style="-fx-text-fill: #757575; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="niveauCB" prefWidth="120"
                              style="-fx-background-color: #F8F9FA; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>
                </VBox>
            </HBox>

            <!-- Ligne 2 -->
            <HBox spacing="20">
                <VBox spacing="5">
                    <Label text="Médecin" style="-fx-text-fill: #757575; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="medecinCB" prefWidth="200"
                              style="-fx-background-color: #F8F9FA; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Survey" style="-fx-text-fill: #757575; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="surveyCB" prefWidth="200"
                              style="-fx-background-color: #F8F9FA; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8;"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>

    <!-- Boutons d'action -->
    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="✏ Modifier" onAction="#modifier"
                style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 25; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(41,121,255,0.25), 8, 0, 0, 2);"/>
        <Button text="🗑 Supprimer" onAction="#supprimer"
                style="-fx-background-color: #FF5252; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 25; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,82,82,0.25), 8, 0, 0, 2);"/>
        <Button text="↺ Actualiser" onAction="#actualiser"
                style="-fx-background-color: #F5F5F5; -fx-text-fill: #757575; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 25; -fx-cursor: hand;"/>
    </HBox>
</VBox>