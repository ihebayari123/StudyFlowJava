<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.connexion3a36.Controller.UserResultsController"
      spacing="0"
      style="-fx-background-color: #f5f5f5;">

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  TOPBAR                                                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <HBox prefHeight="64" alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: white;
                 -fx-border-color: transparent transparent #e0e0e0 transparent;
                 -fx-border-width: 0 0 1 0;">
        <padding><Insets top="0" right="28" bottom="0" left="28"/></padding>

        <VBox spacing="2">
            <Label text="🏁 Résultats du Quiz"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-font-family: 'Georgia'; -fx-text-fill: #1a1a2e;"/>
            <Label text="Voici le détail de votre performance."
                   style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Badge statut -->
        <HBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #e8f5e9; -fx-background-radius: 20;
                     -fx-padding: 6 16;">
            <Label text="✔ Quiz terminé"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
        </HBox>
    </HBox>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  BODY                                                   -->
    <!-- ══════════════════════════════════════════════════════ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <VBox spacing="24">
            <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

            <!-- SCORE HERO -->
            <HBox spacing="20">

                <!-- Score principal -->
                <VBox spacing="14" prefWidth="260" alignment="TOP_LEFT"
                      style="-fx-background-color: #111111; -fx-background-radius: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 16, 0, 0, 5);">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                    <Label text="Votre score"
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-text-fill: #888888; -fx-letter-spacing: 2;"/>

                    <Label fx:id="lblScorePct" text="--"
                           style="-fx-font-size: 52px; -fx-font-weight: bold;
                                  -fx-font-family: 'Georgia'; -fx-text-fill: white;"/>

                    <Label fx:id="lblResultTitle" text="QUIZ TERMINÉ"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>

                    <Label fx:id="lblResultMsg" text="" wrapText="true"
                           style="-fx-font-size: 12px; -fx-text-fill: #aaaaaa;"
                           prefWidth="210"/>
                </VBox>

                <!-- Stats 4 cases -->
                <VBox spacing="12" HBox.hgrow="ALWAYS">

                    <HBox spacing="12">
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-border-color: #eeeeee; -fx-border-radius: 16;
                                     -fx-border-width: 1.5;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
                            <Label fx:id="lblTotal" text="--"
                                   style="-fx-font-size: 30px; -fx-font-weight: bold;
                                          -fx-text-fill: #111111;"/>
                            <Label text="Questions"
                                   style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-border-color: #eeeeee; -fx-border-radius: 16;
                                     -fx-border-width: 1.5;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
                            <Label fx:id="lblPoints" text="--"
                                   style="-fx-font-size: 30px; -fx-font-weight: bold;
                                          -fx-text-fill: #111111;"/>
                            <Label text="Points"
                                   style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="12">
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 16;
                                     -fx-border-color: #c8e6c9; -fx-border-radius: 16;
                                     -fx-border-width: 1.5;">
                            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
                            <Label fx:id="lblCorrect" text="--"
                                   style="-fx-font-size: 30px; -fx-font-weight: bold;
                                          -fx-text-fill: #2e7d32;"/>
                            <Label text="Correctes"
                                   style="-fx-font-size: 11px; -fx-text-fill: #388e3c;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #fce4ec; -fx-background-radius: 16;
                                     -fx-border-color: #f8bbd0; -fx-border-radius: 16;
                                     -fx-border-width: 1.5;">
                            <padding><Insets top="20" right="16" bottom="20" left="16"/></padding>
                            <Label fx:id="lblWrong" text="--"
                                   style="-fx-font-size: 30px; -fx-font-weight: bold;
                                          -fx-text-fill: #c62828;"/>
                            <Label text="Incorrectes"
                                   style="-fx-font-size: 11px; -fx-text-fill: #e53935;"/>
                        </VBox>
                    </HBox>

                </VBox>
            </HBox>

            <!-- RECAPITULATIF LABEL -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Récapitulatif détaillé"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- RECAP LIST -->
            <VBox fx:id="reviewList"
                  style="-fx-background-color: white; -fx-background-radius: 20;
                         -fx-border-color: #eeeeee; -fx-border-radius: 20; -fx-border-width: 1.5;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4);
                         -fx-padding: 8 24;"/>

            <!-- BOUTONS -->
            <HBox spacing="16">
                <Button text="🔄  Rejouer" onAction="#rejouer"
                        prefHeight="46"
                        HBox.hgrow="ALWAYS" maxWidth="10000"
                        style="-fx-background-color: white; -fx-text-fill: #111111;
                               -fx-border-color: #dddddd; -fx-border-radius: 12;
                               -fx-background-radius: 12; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-padding: 12 0; -fx-cursor: hand;"/>
                <Button text="🏠  Accueil Quiz" onAction="#retourHome"
                        prefHeight="46"
                        HBox.hgrow="ALWAYS" maxWidth="10000"
                        style="-fx-background-color: #111111; -fx-text-fill: white;
                               -fx-background-radius: 12; -fx-font-size: 13px;
                               -fx-font-weight: bold; -fx-padding: 12 0; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
