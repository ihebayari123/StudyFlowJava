<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.shape.Circle?>

<AnchorPane
        prefHeight="620.0" prefWidth="580.0"
        style="-fx-background-color: #c8d8e8;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="edu.connexion3a36.Controller.WellBeingScoreController">

    <children>
        <!-- Rectangle de fond avec dégradé bleu -->
        <Rectangle height="620" style="-fx-fill: linear-gradient(to bottom right, #7BAFD4, #B0C9D8, #8A9BAA);" width="580" />

        <VBox alignment="CENTER" layoutX="15" layoutY="15" prefWidth="550" prefHeight="590">

            <VBox prefHeight="590" prefWidth="550" style="-fx-background-color: #F5F6FA; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 8);">

                <HBox VBox.vgrow="ALWAYS">

                    <!-- ======================== SIDEBAR ======================== -->
                    <VBox prefWidth="180" spacing="0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16 0 0 16; -fx-padding: 20 0 20 0;">

                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 16 16 20;">
                            <Circle radius="14" style="-fx-fill: #2979FF;" />
                            <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-padding: 0 0 0 8;" text="EduDoc" />
                        </HBox>

                        <VBox style="-fx-padding: 0 16 20 20; -fx-spacing: 4;">
                            <Label style="-fx-font-size: 10; -fx-text-fill: #9E9E9E;" text="Bien-Être" />
                            <HBox alignment="CENTER_LEFT" spacing="4">
                                <Label style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2979FF;" text="Évaluation" />
                                <Label style="-fx-font-size: 10; -fx-text-fill: #9E9E9E;" text="étudiante" />
                            </HBox>
                            <ProgressBar prefHeight="5" prefWidth="120" progress="0.5" style="-fx-accent: #2979FF; -fx-background-color: #E0E0E0; -fx-background-radius: 4;" />
                        </VBox>

                        <Separator style="-fx-background-color: #F0F0F0;" />

                        <VBox spacing="8" style="-fx-padding: 16 12 0 12;">
                            <Label style="-fx-font-size: 10; -fx-text-fill: #9E9E9E; -fx-padding: 0 0 4 8;" text="INDICATEURS" />

                            <!-- Indicateur Stress -->
                            <VBox spacing="4" style="-fx-background-color: #E8F0FE; -fx-background-radius: 10; -fx-padding: 12;">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 14;" text="💚" />
                                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #2979FF;" text="Stress" />
                                </HBox>
                                <Label text="Mesurez votre niveau actuel"
                                       style="-fx-font-size: 10; -fx-text-fill: #757575;"/>
                            </VBox>

                            <!-- Indicateur Académique -->
                            <VBox spacing="4" style="-fx-background-color: #F5F5F5; -fx-background-radius: 10; -fx-padding: 12;">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 14;" text="📘" />
                                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Académique" />
                                </HBox>
                                <Label text="Impact sur vos études"
                                       style="-fx-font-size: 10; -fx-text-fill: #757575;"/>
                            </VBox>

                            <!-- Indicateur Activité -->
                            <VBox spacing="4" style="-fx-background-color: #F5F5F5; -fx-background-radius: 10; -fx-padding: 12;">
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 14;" text="🏃" />
                                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Activité" />
                                </HBox>
                                <Label text="Habitudes physiques"
                                       style="-fx-font-size: 10; -fx-text-fill: #757575;"/>
                            </VBox>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <!-- Badge Score -->
                        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: #2979FF; -fx-background-radius: 12; -fx-padding: 16; -fx-margin: 10;">
                            <Label text="SCORE"
                                   style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-weight: bold;"/>
                            <Label text="0–100"
                                   style="-fx-font-size: 24px; -fx-text-fill: white; -fx-font-weight: bold;"/>
                            <Label text="Points de bien-être"
                                   style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.6);"/>
                        </VBox>
                    </VBox>

                    <!-- ======================== FORMULAIRE ======================== -->
                    <VBox prefWidth="370" spacing="16" style="-fx-background-color: #F5F6FA; -fx-background-radius: 0 16 16 0; -fx-padding: 20 25 20 25;">

                        <!-- Header du formulaire -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Rectangle height="24" width="4" style="-fx-fill: #2979FF; -fx-arc-width: 2; -fx-arc-height: 2;" />
                            <Label text="Évaluation du Bien-Être"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
                        </HBox>

                        <Label text="Formulaire de suivi — Santé Mentale &amp; Académique"
                               style="-fx-font-size: 11px; -fx-text-fill: #9E9E9E; -fx-font-family: 'Segoe UI';"/>

                        <Separator style="-fx-background-color: #E0E0E0;" />

                        <Label text="SAISIR LES DONNÉES"
                               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #2979FF; -fx-font-family: 'Segoe UI';"/>

                        <!-- Recommandation -->
                        <VBox spacing="4">
                            <Label text="Recommandation Médicale"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
                            <TextField fx:id="recommendationTF" promptText="Ex : Pratiquer 20 min de relaxation..." prefHeight="38"
                                       style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-family: 'Segoe UI'; -fx-font-size: 12px;"/>
                        </VBox>

                        <!-- Plan d'Action -->
                        <VBox spacing="4">
                            <Label text="Plan d'Action Proposé"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
                            <TextField fx:id="actionPlanTF" promptText="Ex : Pause de 5 min toutes les heures..." prefHeight="38"
                                       style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-family: 'Segoe UI'; -fx-font-size: 12px;"/>
                        </VBox>

                        <!-- Commentaire -->
                        <VBox spacing="4">
                            <Label text="Observations Cliniques"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
                            <TextField fx:id="commentTF" promptText="Ex : Étudiant en période d'examens..." prefHeight="38"
                                       style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-family: 'Segoe UI'; -fx-font-size: 12px;"/>
                        </VBox>

                        <!-- Score -->
                        <VBox spacing="4">
                            <Label text="Score de Bien-Être (0 — 100)"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-font-family: 'Segoe UI';"/>
                            <TextField fx:id="scoreTF" promptText="Ex : 78" prefHeight="38"
                                       style="-fx-background-color: white; -fx-border-color: #2979FF; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2979FF;"/>
                        </VBox>

                        <!-- Boutons -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <VBox.margin><Insets top="8"/></VBox.margin>
                            <Button text="✦ Enregistrer l'Évaluation" onAction="#ajouter"
                                    prefHeight="40" prefWidth="220"
                                    style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(41,121,255,0.25), 8, 0, 0, 2);"/>
                            <Button text="↺ Réinitialiser"
                                    prefHeight="36" prefWidth="100"
                                    style="-fx-background-color: transparent; -fx-text-fill: #757575; -fx-font-size: 11px; -fx-font-family: 'Segoe UI'; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>

                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>