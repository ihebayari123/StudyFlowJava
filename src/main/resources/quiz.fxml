<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.Controller.QuizController">

    <VBox spacing="8">
        <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="❓ Quiz" />
        <Label style="-fx-font-size: 14; -fx-text-fill: #757575;" text="Testez vos connaissances" />
    </VBox>

    <VBox spacing="16">

        <HBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 20; -fx-cursor: hand;">
            <StackPane prefHeight="50" prefWidth="50" style="-fx-background-color: #E8F0FE; -fx-background-radius: 12;">
                <Label style="-fx-font-size: 24;" text="📘" />
            </StackPane>
            <VBox HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Quiz Java - Fondamentaux" />
                <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="10 questions · 20 minutes" />
                <Label style="-fx-font-size: 11; -fx-text-fill: #4CAF50;" text="Score: 8/10" />
            </VBox>
            <Button text="Réviser" style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16;" />
        </HBox>

        <HBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 20; -fx-cursor: hand;">
            <StackPane prefHeight="50" prefWidth="50" style="-fx-background-color: #E8F5E9; -fx-background-radius: 12;">
                <Label style="-fx-font-size: 24;" text="🗄️" />
            </StackPane>
            <VBox HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Quiz SQL - Les requêtes" />
                <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="8 questions · 15 minutes" />
                <Label style="-fx-font-size: 11; -fx-text-fill: #FF9800;" text="Score: 6/8" />
            </VBox>
            <Button text="Réviser" style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16;" />
        </HBox>

        <HBox spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 20; -fx-cursor: hand;">
            <StackPane prefHeight="50" prefWidth="50" style="-fx-background-color: #FFF3E0; -fx-background-radius: 12;">
                <Label style="-fx-font-size: 24;" text="🌐" />
            </StackPane>
            <VBox HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Quiz HTML/CSS" />
                <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="12 questions · 25 minutes" />
                <Label style="-fx-font-size: 11; -fx-text-fill: #F44336;" text="Non commencé" />
            </VBox>
            <Button text="Commencer" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16;" />
        </HBox>

    </VBox>

</VBox>