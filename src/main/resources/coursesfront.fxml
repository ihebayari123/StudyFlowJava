<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.CoursesFrontController"
      spacing="0"
      style="-fx-background-color: #f5f5f5;">

    <!-- HEADER -->
    <HBox prefHeight="90" alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: linear-gradient(to right, #e8f0fe, #fce4ec);
                 -fx-border-color: transparent transparent #e0e0e0 transparent;
                 -fx-border-width: 0 0 1 0;">
        <padding><Insets top="0" right="28" bottom="0" left="28"/></padding>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Mes Cours"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-font-family: 'Georgia'; -fx-text-fill: #1a237e;"/>
            <Label fx:id="subtitleLabel" text="Découvrez et gérez vos cours"
                   style="-fx-font-size: 12px; -fx-text-fill: #5c6bc0;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="🔍  Rechercher un cours..."
                   prefWidth="220" prefHeight="36" onKeyReleased="#handleSearch"
                   style="-fx-background-radius: 20; -fx-background-color: white;
                          -fx-border-color: #dddddd; -fx-border-radius: 20; -fx-padding: 6 14; -fx-font-size: 13px;"/>
        <Button text="Tout afficher" onAction="#handleShowAll"
                style="-fx-background-color: white; -fx-border-color: #ddd;
                       -fx-border-radius: 10; -fx-background-radius: 10;
                       -fx-padding: 8 14; -fx-cursor: hand; -fx-font-size: 12px;"/>
        <Button text="+ Nouveau cours" onAction="#handleAddCourse"
                style="-fx-background-color: #1565c0; -fx-text-fill: white;
                       -fx-background-radius: 12; -fx-font-size: 13px;
                       -fx-font-weight: bold; -fx-padding: 10 18; -fx-cursor: hand;"/>
        <Label text="📚" style="-fx-font-size: 40px;"/>
    </HBox>

    <!-- STATS ROW -->
    <HBox spacing="12" style="-fx-padding: 16 28 0 28;">
        <HBox prefWidth="180" prefHeight="64"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #eeeeee; -fx-border-radius: 14;"
              spacing="8" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label fx:id="lblTotalCourses" text="0"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
            <VBox>
                <Label text="Cours" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                <Label text="au total" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
            </VBox>
        </HBox>
        <HBox prefWidth="180" prefHeight="64"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #eeeeee; -fx-border-radius: 14;"
              spacing="8" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label fx:id="lblTotalChapitres" text="0"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6a1b9a;"/>
            <VBox>
                <Label text="Chapitres" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
                <Label text="disponibles" style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
            </VBox>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Label text="Filtrer :" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
            <Button fx:id="filterAll" text="Tous" userData="all" onAction="#handleFilter"
                    style="-fx-background-color: #1565c0; -fx-text-fill: white;
                           -fx-background-radius: 20; -fx-font-size: 12px; -fx-padding: 5 14; -fx-cursor: hand;"/>
            <Button fx:id="filterRecent" text="Récents" userData="recent" onAction="#handleFilter"
                    style="-fx-background-color: #eeeeee; -fx-text-fill: #555;
                           -fx-background-radius: 20; -fx-font-size: 12px; -fx-padding: 5 14; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- STATUS -->
    <HBox style="-fx-padding: 10 28 4 28;" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" text="Chargement des cours..."
               style="-fx-font-size: 12px; -fx-text-fill: #9e9e9e;"/>
    </HBox>

    <!-- COURSES GRID -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <padding><Insets top="8" right="28" bottom="28" left="28"/></padding>
        <FlowPane fx:id="coursesGrid" hgap="16" vgap="16" prefWrapLength="800"/>
    </ScrollPane>

</VBox>