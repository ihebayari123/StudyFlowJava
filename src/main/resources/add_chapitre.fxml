<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16"
      style="-fx-padding: 24; -fx-background-color: #F5F6FA;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.AddChapitreController">

    <!-- Title -->
    <Label fx:id="formTitle" text="➕ Ajouter un Chapitre"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" />

    <Separator />

    <!-- Titre -->
    <VBox spacing="4">
        <Label text="Titre *" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
        <TextField fx:id="titreField" promptText="Titre du chapitre"
                   style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;" />
        <Label fx:id="titreErrorLabel" text="" visible="false"
               style="-fx-text-fill: red; -fx-font-size: 11;" />
    </VBox>

    <!-- Contenu -->
    <VBox spacing="4">
        <Label text="Contenu *" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
        <TextArea fx:id="contenuField" promptText="Contenu / description du chapitre"
                  prefHeight="120" wrapText="true"
                  style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;" />
        <Label fx:id="contenuErrorLabel" text="" visible="false"
               style="-fx-text-fill: red; -fx-font-size: 11;" />
    </VBox>

    <!-- Ordre + Type (row) -->
    <HBox spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Ordre *" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
            <TextField fx:id="ordreField" promptText="ex: 1"
                       style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;" />
            <Label fx:id="ordreErrorLabel" text="" visible="false"
                   style="-fx-text-fill: red; -fx-font-size: 11;" />
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Type de contenu" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
            <ComboBox fx:id="contentTypeBox" prefWidth="200"
                      style="-fx-background-radius: 6; -fx-padding: 4 8;" />
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Durée (minutes)" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
            <TextField fx:id="durationField" promptText="ex: 45"
                       style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;" />
        </VBox>
    </HBox>

    <!-- Optional fields -->
    <TitledPane text="Champs optionnels (URL vidéo, image, fichier)"
                expanded="false"
                style="-fx-background-color: #FFFFFF; -fx-background-radius: 8;">
        <VBox spacing="12" style="-fx-padding: 12;">
            <VBox spacing="4">
                <Label text="URL Vidéo" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
                <TextField fx:id="videoUrlField" promptText="https://youtube.com/..."
                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;" />
            </VBox>
            <VBox spacing="4">
                <Label text="URL Image" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
                <TextField fx:id="imageUrlField" promptText="https://..."
                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;" />
            </VBox>
            <VBox spacing="4">
                <Label text="Nom du fichier" style="-fx-font-weight: bold; -fx-text-fill: #333;" />
                <TextField fx:id="fileNameField" promptText="document.pdf"
                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8 12;" />
            </VBox>
        </VBox>
    </TitledPane>

    <Separator />

    <!-- Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel"
                style="-fx-background-color: #E0E0E0; -fx-text-fill: #333; -fx-cursor: hand;
                        -fx-background-radius: 8; -fx-padding: 10 20;" />
        <Button fx:id="saveButton" text="💾  Enregistrer" onAction="#handleSave"
                style="-fx-background-color: #2979FF; -fx-text-fill: white; -fx-font-weight: bold;
                        -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 10 20;" />
    </HBox>

</VBox>
