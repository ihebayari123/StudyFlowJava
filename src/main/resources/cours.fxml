<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.Controller.CoursController"
      spacing="10" style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Gestion des Cours" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addCourseBtn" text="+ Nouveau Cours"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"
                onAction="#handleAddCourse"/>
    </HBox>

    <!-- Search Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher un cours..."
                   HBox.hgrow="ALWAYS"
                   style="-fx-padding: 8px; -fx-border-radius: 5px;"/>
        <Button text="🔍" onAction="#handleSearch"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Button text="Tous" onAction="#handleShowAll"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <!-- Courses Table -->
    <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="ID" fx:id="idColumn" prefWidth="60"/>
            <TableColumn text="Titre" fx:id="titleColumn" prefWidth="250"/>
            <TableColumn text="Description" fx:id="descriptionColumn" prefWidth="350"/>
            <TableColumn text="Image" fx:id="imageColumn" prefWidth="100"/>
            <TableColumn text="Actions" fx:id="actionsColumn" prefWidth="150"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- Status Bar -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="statusLabel" text="Prêt" style="-fx-text-fill: #7f8c8d;"/>
    </HBox>

</VBox>