<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="20" style="-fx-padding: 24; -fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.Controller.CoursController">

    <VBox spacing="8">
        <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="📚 Mes Cours" />
        <Label style="-fx-font-size: 14; -fx-text-fill: #757575;" text="Continuez votre apprentissage" />
    </VBox>

    <HBox spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 12 16;">
        <Label text="🔍" />
        <Label style="-fx-text-fill: #9E9E9E;" text="Rechercher un cours..." HBox.hgrow="ALWAYS" />
    </HBox>
   <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="86.0" text="ajouter cours" />

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="16">

            <!-- Cours 1: Programmation Java -->
            <HBox fx:id="courseJava" spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2); -fx-cursor: hand;">
                <StackPane prefHeight="60" prefWidth="60" style="-fx-background-color: #E8F0FE; -fx-background-radius: 12;">
                    <Label style="-fx-font-size: 28;" text="📘" />
                </StackPane>
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Programmation Java" />
                    <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="8 chapitres · 3 quiz · 12 exercices" />
                    <HBox spacing="8">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #2979FF;" text="Progression: 65%" />
                        <Rectangle height="4" style="-fx-fill: #E0E0E0; -fx-arc-width: 2; -fx-arc-height: 2;" width="150" />
                        <Rectangle height="4" style="-fx-fill: #2979FF; -fx-arc-width: 2; -fx-arc-height: 2;" width="97" />
                    </HBox>
                </VBox>
                <Label style="-fx-font-size: 16; -fx-text-fill: #9E9E9E;" text="→" />
            </HBox>

            <!-- Cours 2: Base de données -->
            <HBox fx:id="courseSQL" spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2); -fx-cursor: hand;">
                <StackPane prefHeight="60" prefWidth="60" style="-fx-background-color: #E8F5E9; -fx-background-radius: 12;">
                    <Label style="-fx-font-size: 28;" text="🗄️" />
                </StackPane>
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Base de données SQL" />
                    <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="6 chapitres · 2 quiz · 8 exercices" />
                    <HBox spacing="8">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #2979FF;" text="Progression: 40%" />
                        <Rectangle height="4" style="-fx-fill: #E0E0E0; -fx-arc-width: 2; -fx-arc-height: 2;" width="150" />
                        <Rectangle height="4" style="-fx-fill: #2979FF; -fx-arc-width: 2; -fx-arc-height: 2;" width="60" />
                    </HBox>
                </VBox>
                <Label style="-fx-font-size: 16; -fx-text-fill: #9E9E9E;" text="→" />
            </HBox>

            <!-- Cours 3: Développement Web -->
            <HBox fx:id="courseWeb" spacing="16" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2); -fx-cursor: hand;">
                <StackPane prefHeight="60" prefWidth="60" style="-fx-background-color: #FFF3E0; -fx-background-radius: 12;">
                    <Label style="-fx-font-size: 28;" text="🌐" />
                </StackPane>
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;" text="Développement Web" />
                    <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="10 chapitres · 4 quiz · 15 exercices" />
                    <HBox spacing="8">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #2979FF;" text="Progression: 25%" />
                        <Rectangle height="4" style="-fx-fill: #E0E0E0; -fx-arc-width: 2; -fx-arc-height: 2;" width="150" />
                        <Rectangle height="4" style="-fx-fill: #2979FF; -fx-arc-width: 2; -fx-arc-height: 2;" width="37" />
                    </HBox>
                </VBox>
                <Label style="-fx-font-size: 16; -fx-text-fill: #9E9E9E;" text="→" />
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>
