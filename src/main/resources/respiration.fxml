<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.TextAlignment?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.connexion3a36.Controller.RespirationController"
           style="-fx-background-color: linear-gradient(to bottom, #e8f5e9, #c8e6c9);">

    <!-- Top Section - Title -->
    <top>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
            <Label text="🌬️ Exercice de Respiration Avancée"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
            <Label text="Technique 4-7-8 pour réduire le stress et l'anxiété"
                   style="-fx-font-size: 16px; -fx-text-fill: #558b2f;"/>
        </VBox>
    </top>

    <!-- Center Section - Breathing Animation and Messages -->
    <center>
        <VBox alignment="CENTER" spacing="30" style="-fx-padding: 20;">

            <!-- Breathing Circle Indicator -->
            <VBox alignment="CENTER">
                <Label fx:id="breathPhaseLabel"
                       text="Prêt à commencer"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1b5e20;"
                       textAlignment="CENTER"/>
                <Label fx:id="breathTimerLabel"
                       text=""
                       style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"
                       textAlignment="CENTER"/>
                <Label fx:id="breathInstructionLabel"
                       text="Appuyez sur 'Démarrer' pour commencer"
                       style="-fx-font-size: 16px; -fx-text-fill: #558b2f;"
                       textAlignment="CENTER"/>
            </VBox>

            <!-- Motivational Messages Area -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
                <Label text="💬 Messages de Motivation"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                <TextArea fx:id="motivationText"
                          editable="false"
                          prefWidth="400" prefHeight="100"
                          wrapText="true"
                          style="-fx-font-size: 14px; -fx-text-fill: #333333; -fx-background-color: #ffffff; -fx-border-color: #a5d6a7; -fx-border-radius: 10; -fx-background-radius: 10;"/>
            </VBox>

            <!-- Control Buttons -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="btnStart"
                        text="▶  Démarrer"
                        onAction="#startBreathing"
                        prefWidth="150" prefHeight="50"
                        style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #4caf50; -fx-background-radius: 25;"/>
                <Button fx:id="btnStop"
                        text="⏹  Arrêter"
                        onAction="#stopBreathing"
                        prefWidth="150" prefHeight="50"
                        disable="true"
                        style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #f44336; -fx-background-radius: 25;"/>
            </HBox>

            <!-- Cycle Counter -->
            <Label fx:id="cycleCounterLabel"
                   text="Cycle: 0 / 4"
                   style="-fx-font-size: 16px; -fx-text-fill: #558b2f;"/>
        </VBox>
    </center>

    <!-- Bottom Section - Navigation Buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="30" style="-fx-padding: 30;">
            <Button fx:id="btnBack"
                    text="← Retour"
                    onAction="#goBack"
                    prefWidth="180" prefHeight="45"
                    style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #78909c; -fx-background-radius: 25;"/>
            <Button fx:id="btnDashboard"
                    text="🏠 Tableau de bord"
                    onAction="#goToDashboard"
                    prefWidth="180" prefHeight="45"
                    style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #1565c0; -fx-background-radius: 25;"/>
        </HBox>
    </bottom>

</BorderPane>